{
  "manifest_version": 3,
  "name": "JobHunt Pro — AI Sidecar & Auto-Applier",
  "version": "2.0.0",
  "description": "Instant 1-Click AI Auto-Apply, ATS Keyword Scoring & Cover Letter Generator for LinkedIn, Indeed, and Wuzzuf.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://*.wuzzuf.net/*",
    "http://localhost:8000/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.linkedin.com/*",
        "https://*.indeed.com/*",
        "https://*.wuzzuf.net/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
