{
  "manifest_version": 3,
  "name": "JobHunt Pro - Ghost Applier",
  "version": "1.1.0",
  "description": "Zero-Cost AI Job Application directly from LinkedIn using ChatGPT session piggybacking.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "https://www.linkedin.com/jobs/*",
    "https://chatgpt.com/*",
    "https://mail.google.com/*",
    "https://jhfguf.pythonanywhere.com/*",
    "http://127.0.0.1:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*"
      ],
      "js": ["scraper-content.js"],
      "css": ["content.css"]
    },
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": ["chatgpt-content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": ["gmail-content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
