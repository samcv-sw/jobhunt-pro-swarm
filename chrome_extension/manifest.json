{
  "manifest_version": 3,
  "name": "JobHunt Pro - Ghost Applier",
  "version": "1.0.0",
  "description": "1-Click AI Job Application directly from LinkedIn and Indeed.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://www.linkedin.com/jobs/*",
    "https://www.indeed.com/viewjob*",
    "http://127.0.0.1:8000/*",
    "https://jhfguf.pythonanywhere.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://www.indeed.com/viewjob*"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
