<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Job Application</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            line-height: 1.6;
            color: #333333;
            max-width: 600px;
            margin: 0 auto;
            padding: 20px;
        }
        .header {
            border-bottom: 2px solid #0056b3;
            padding-bottom: 15px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
        }
        .initials-badge {
            background-color: #0056b3;
            color: #ffffff;
            font-size: 24px;
            font-weight: bold;
            width: 50px;
            height: 50px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 15px;
        }
        .candidate-info {
            flex-grow: 1;
        }
        .candidate-name {
            font-size: 20px;
            font-weight: bold;
            margin: 0;
            color: #0056b3;
        }
        .candidate-profession {
            font-size: 14px;
            color: #666666;
            margin: 2px 0 0 0;
            text-transform: uppercase;
        }
        .content {
            font-size: 16px;
            white-space: pre-line;
            margin-top: 20px;
        }
        .footer {
            margin-top: 40px;
            padding-top: 15px;
            border-top: 1px solid #eeeeee;
            font-size: 12px;
            color: #777777;
        }
        .unsubscribe-link {
            color: #0056b3;
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <div class="header">
        {% if initials %}
        <div class="initials-badge">{{ initials }}</div>
        {% endif %}
        <div class="candidate-info">
            <h1 class="candidate-name">{{ sender_name }}</h1>
            {% if profession %}
            <p class="candidate-profession">{{ profession }}</p>
            {% endif %}
        </div>
    </div>
    
    <div class="content">
        Dear {{ recipient_name or "Hiring Manager" }},

        {{ cover_letter_body }}

        Best regards,
        {{ sender_name }}
    </div>
    
    <div class="footer">
        This email was sent via JobHunt Pro. If you no longer wish to receive these emails, you can 
        <a class="unsubscribe-link" href="{{ unsubscribe_url }}">unsubscribe here</a>.
        {% if tracking_pixel_url %}
        <img src="{{ tracking_pixel_url }}" width="1" height="1" alt="" style="display:none;" />
        {% endif %}
    </div>
</body>
</html>
