{
  "version": 2,
  "name": "jobhunt-pro-frontend",
  "builds": [
    {
      "src": "web/app_v2.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/web/static/$1",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "web/app_v2.py"
    }
  ]
}
