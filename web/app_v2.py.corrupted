<script>
function copyText(btn) {{
    var card = btn.closest('.wr-card');
    var body = card ? card.querySelector('.wr-card-body') : null;
    var text = body ? body.innerText : '';
    if (!text) return;
    navigator.clipboard.writeText(text).then(function() {{
        btn.innerHTML = '<span class="copy-icon">âœ...</span> COPIED!';
        btn.classList.add('copied');
        setTimeout(function() {{ btn.innerHTML = '<span class="copy-icon">ðŸ"‹</span> COPY TO CLIPBOARD'; btn.classList.remove('copied'); }}, 2000);
    }});
}}
function copyHtml(btn) {{
    var card = btn.closest('.wr-card');
    var body = card ? card.querySelector('.cover-preview') : null;
    var text = body ? body.innerHTML : '';
    if (!text) return;
    navigator.clipboard.writeText(text).then(function() {{
        btn.innerHTML = '<span class="copy-icon">âœ...</span> COPIED!';
        btn.classList.add('copied');
        setTimeout(function() {{ btn.innerHTML = '<span class="copy-icon">ðŸ"‹</span> COPY HTML'; btn.classList.remove('copied'); }}, 2000);
    }});
}}
</script>
'''
    user_dict = {"wallet_balance": user.get("wallet_balance", 0)}
    html = _build_dashboard_shell(user_dict, user_id, content, "&#x2694;&#xFE0F; War Room", "war-room")
    return HTMLResponse(content=html)

@app.get("/war-room", response_class=HTMLResponse)
async def war_room_standalone(request: Request):
    """Standalone War Room â€" redirects to Battle Station overview."""
    user_id = get_verified_user_id(request)
    if not user_id:
        return RedirectResponse("/login", status_code=303)
    return RedirectResponse("/battle-station", status_code=303)

@app.get("/battle-station", response_class=HTMLResponse)
async def battle_station_page(request: Request):
    """Battle Station: live campaign control center with military-themed dashboard."""
    user_id = get_verified_user_id(request)
    if not user_id:
        return RedirectResponse("/login", status_code=303)
    conn = get_db()
    user_row = conn.execute("SELECT * FROM users WHERE user_id = ?", (user_id,)).fetchone()
    user = dict(user_row) if user_row else {}
    campaigns = [dict(r) for r in conn.execute(
        "SELECT * FROM campaigns WHERE user_id = ? ORDER BY created_at DESC LIMIT 20",
        (user_id,)).fetchall()]
    conn.close()

    # Campaign health stats
    running_count = sum(1 for c in campaigns if c.get('status') == 'running')
    completed_count = sum(1 for c in campaigns if c.get('status') == 'completed')
    paused_count = sum(1 for c in campaigns if c.get('status') == 'paused')
    failed_count = sum(1 for c in campaigns if c.get('status') == 'failed')
    total_sent = sum(c.get('sent_count', 0) or 0 for c in campaigns)
    total_responses = sum(c.get('response_count', 0) or 0 for c in campaigns)

    return templates.TemplateResponse("battle_station.html", {
        "request": request,
        "active_page": "battle-station",
        "user": user,
        "campaigns": campaigns,
        "running_count": running_count,
        "completed_count": completed_count,
        "paused_count": paused_count,
        "failed_count": failed_count,
        "total_sent": total_sent,
        "total_responses": total_responses,
    })

@app.get("/wallet", response_class=HTMLResponse)
async def wallet_page(request: Request):
    user_id = get_verified_user_id(request)
    if not user_id:
        return RedirectResponse("/login", status_code=303)

    conn = get_db()
    user_row = conn.execute("SELECT * FROM users WHERE user_id = ?", (user_id,)).fetchone()
    if not user_row:
        conn.close()
        return RedirectResponse("/login", status_code=303)
    user = dict(user_row)
    transactions = [dict(r) for r in conn.execute(
        "SELECT * FROM wallet_transactions WHERE user_id = ? ORDER BY created_at DESC LIMIT 50",
        (user_id,)).fetchall()]
    conn.close()

    crypto_addresses = get_payment_addresses()

    return templates.TemplateResponse(request, "wallet.html", {"active_page": "wallet",
        "user": user, "transactions": transactions,
        "crypto_addresses": crypto_addresses
    })


@app.post("/wallet/regenerate-key")
async def wallet_regenerate_key(request: Request):
    user_id = get_verified_user_id(request)
    if not user_id:
        return RedirectResponse("/login", status_code=303)
    new_key = f"jhp_{uuid.uuid4().hex[:32]}"
