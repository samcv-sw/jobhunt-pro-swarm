@app.get("/api/v1/stats")
async def api_miniapp_stats():
    """Stats for Telegram Mini App Dashboard."""
    conn = None
    try:
        conn = get_db()
        conn.row_factory = sqlite3.Row
        now = _time.time()
        today_start = now - (now % 86400)

        c = conn.execute("SELECT COUNT(*) as cnt FROM applications")
        total = c.fetchone()['cnt']

        c = conn.execute("SELECT COUNT(*) as cnt FROM applications WHERE sent_at > ?", (today_start,))
        today = c.fetchone()['cnt']

        c = conn.execute("SELECT COUNT(*) as cnt FROM applications WHERE responded = 1")
        responses = c.fetchone()['cnt']

        c = conn.execute("SELECT COUNT(*) as cnt FROM applications WHERE response_type = 'interview'")
        interviews = c.fetchone()['cnt']

        response_rate = round((responses / total * 100), 1) if total > 0 else 0

        return {
            "today": today,
            "total": total,
            "responses": responses,
            "interviews": interviews,
            "response_rate": response_rate
        }
    finally:
        if conn:
            conn.close()


@app.get("/api/v1/trends")
async def api_miniapp_trends(days: int = 7):
    """Application trends for Mini App chart."""
    conn = None
    try:
        conn = get_db()
        conn.row_factory = sqlite3.Row
        now = int(_time.time())

        dates = []
        counts = []
        for i in range(days - 1, -1, -1):
            day_start = now - (now % 86400) - (i * 86400)
            day_end = day_start + 86400
            c = conn.execute(
                "SELECT COUNT(*) as cnt FROM applications WHERE sent_at >= ? AND sent_at < ?",
                (day_start, day_end)
            )
            counts.append(c.fetchone()['cnt'])
            dates.append(_time.strftime('%a', _time.gmtime(day_start)))

        return {"dates": dates, "counts": counts}
    finally:
        if conn:
            conn.close()


