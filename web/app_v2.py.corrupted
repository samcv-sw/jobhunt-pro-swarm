@app.get("/api/v1/jobs")
async def api_v1_jobs(request: Request):
    """Return all jobs for the logged-in user as JSON."""
    user = _get_session_user(request)
    if not user:
        return JSONResponse({"error": "Not logged in"}, status_code=401)
    user_id = user.get("id")
    conn = get_db()
    try:
        cursor = conn.execute(
            "SELECT * FROM jobs WHERE user_id = ? ORDER BY created_at DESC",
            (user_id,)
        )
        rows = cursor.fetchall()
        columns = [col[0] for col in cursor.description]
        jobs = [dict(zip(columns, row)) for row in rows]
        conn.close()
        return JSONResponse({"jobs": jobs, "count": len(jobs)})
    except Exception as e:
        conn.close()
        logger.exception("api_v1_jobs failed")
        return JSONResponse({"error": str(e)}, status_code=500)


# ============ JSON API Login (was 404 - FIXED 2026-06-04) ============
@app.post("/api/v1/login")
async def api_v1_login(request: Request):
    """JSON API login â€" returns user object or error."""
    conn = None
    try:
        data = await request.json()
        email = data.get("email", "").strip().lower()
        password = data.get("password", "")
        if not email or not password:
            return JSONResponse({"error": "Email and password required"}, status_code=400)
        conn = get_db()
        cursor = conn.execute(
            "SELECT * FROM users WHERE email = ?", (email,)
        )
        row = cursor.fetchone()
        if not row:
            conn.close()
            return JSONResponse({"error": "Invalid credentials"}, status_code=401)
        columns = [col[0] for col in cursor.description]
        user_dict = dict(zip(columns, row))
        stored_hash = user_dict.get("password_hash", "")
        if not verify_password(password, stored_hash):
            conn.close()
            return JSONResponse({"error": "Invalid credentials"}, status_code=401)
        conn.close()
        request.session["user"] = {
            "id": user_dict["id"],
            "email": user_dict["email"],
            "name": user_dict.get("name", email.split("@")[0]),
            "wallet_balance": user_dict.get("wallet_balance", 0)
        }
        return JSONResponse({"user": {"id": user_dict["id"], "email": user_dict["email"], "name": user_dict.get("name")}})
    except json.JSONDecodeError:
        if conn:
            conn.close()
        return JSONResponse({"error": "Invalid JSON body"}, status_code=400)
    except Exception as e:
        if conn:
            conn.close()
        logger.exception("api_v1_login")
        return JSONResponse({"error": str(e)}, status_code=500)


# ============ JSON API Register (FIXED 2026-06-05) ============
@app.post("/api/v1/register")
async def api_v1_register(request: Request):
    """JSON API registration â€" creates user and returns API key."""
    conn = None
    try:
        data = await request.json()
    except Exception:
        return JSONResponse({"error": "Invalid JSON body"}, status_code=400)

    email = data.get("email", "").strip().lower()
    password = data.get("password", "")
    name = data.get("name", "")
    phone = data.get("phone", "")

    if not email or not password:
        return JSONResponse({"error": "Email and password required"}, status_code=400)
    if len(password) < 8:
        return JSONResponse({"error": "Password must be at least 8 characters"}, status_code=400)
    if len(name) < 1:
        name = email.split("@")[0]

    try:
        conn = get_db()
        existing = conn.execute("SELECT id FROM users WHERE email = ?", (email,)).fetchone()
        if existing:
            conn.close()
            return JSONResponse({"error": "Email already registered"}, status_code=409)

        user_id = uuid.uuid4().hex
        api_key = uuid.uuid4().hex
        password_hash = hash_password(password)

        conn.execute(
            "INSERT INTO users (user_id, email, password_hash, name, phone, user_type, api_key) VALUES (?, ?, ?, ?, ?, 'jobseeker', ?)",
            (user_id, email, password_hash, name, phone, api_key)
        )
        conn.commit()
        conn.close()

        return JSONResponse({
            "user": {"id": user_id, "email": email, "name": name},
            "api_key": api_key
        }, status_code=201)
    except Exception as e:
        if conn:
            try:
                conn.close()
            except Exception:
                pass
        logger.exception("api_v1_register")
        return JSONResponse({"error": str(e)}, status_code=500)


# ============ Groq Proxy for Local Bot (Cloudflare blocks Lebanon IP) ============
@app.post("/api/v1/groq-proxy")
async def api_groq_proxy(request: Request):
    """Proxy Groq API calls through PA's US IP to bypass Cloudflare block on Lebanon.
    Body: {"messages": [...], "model": "llama-3.1-8b-instant", "temperature": 0.7, "max_tokens": 200}
    """
    import httpx, random
    try:
        data = await request.json()
        messages = data.get("messages", [{"role": "user", "content": "hi"}])
        model = data.get("model", "llama-3.1-8b-instant")
        temperature = data.get("temperature", 0.7)
        max_tokens = data.get("max_tokens", 500)
        # Rotate keys
        api_key = random.choice(GROQ_KEYS)
        async with httpx.AsyncClient(timeout=30) as client:
            resp = await client.post(
                "https://api.groq.com/openai/v1/chat/completions",
                headers={"Authorization": f"Bearer {api_key}", "Content-Type": "application/json"},
                json={"model": model, "messages": messages, "temperature": temperature, "max_tokens": max_tokens}
            )
            if resp.status_code != 200:
                logger.warning(f"Groq proxy: HTTP {resp.status_code}: {resp.text[:200]}")
            return JSONResponse(resp.json(), status_code=resp.status_code)
    except Exception as e:
        logger.exception("groq-proxy failed")
        return JSONResponse({"error": str(e)}, status_code=500)


# === Public Job Search API ===
@app.get("/api/v1/search")
async def api_v1_search(request: Request, q: str = ""):
    """Public job search endpoint."""
    try:
        if not q or len(q.strip()) < 2:
            return JSONResponse({"error": "Search query must be at least 2 characters"}, status_code=400)
        conn = get_db()
        try:
            search_term = f"%{q.strip()}%"
            rows = conn.execute(
                "SELECT id, company, title, location, salary, created_at, source "
                "FROM jobs WHERE (title LIKE ? OR company LIKE ? OR snippet LIKE ?) "
                "ORDER BY created_at DESC LIMIT 50",
                (search_term, search_term, search_term)
            ).fetchall()
            results = [{
                "id": r[0], "company": r[1], "title": r[2], "location": r[3],
                "salary": r[4], "posted": r[5], "source": r[6]
            } for r in rows]
            return JSONResponse({"query": q, "count": len(results), "results": results})
        finally:
            conn.close()
    except Exception as e:
        logger.exception("api_v1_search failed")
        return JSONResponse({"error": str(e)}, status_code=500)


