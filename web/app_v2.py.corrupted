    conn = get_db()
    campaign_row = conn.execute("SELECT * FROM campaigns WHERE campaign_id = ? AND user_id = ?",
                                 (campaign_id, user_id)).fetchone()
    if not campaign_row:
        conn.close()
        return RedirectResponse("/dashboard", status_code=303)
    campaign = dict(campaign_row)
    emails = [dict(r) for r in conn.execute(
        "SELECT * FROM campaign_emails WHERE campaign_id = ? ORDER BY sent_at DESC",
        (campaign_id,)).fetchall()]
    conn.close()

    return templates.TemplateResponse(request, "campaign_detail.html", {"active_page": "campaign",
        "campaign": campaign, "emails": emails
    })

@app.get("/campaign/{campaign_id}/war-room", response_class=HTMLResponse)
async def campaign_war_room(request: Request, campaign_id: str):
    user_id = get_verified_user_id(request)
    if not user_id:
        return RedirectResponse("/login", status_code=303)
    conn = get_db()
    # Migrations: ensure new columns exist
    for col, typ in [("cover_html", "TEXT DEFAULT ''"), ("competition_score", "INTEGER DEFAULT 0"), ("followup_scheduled", "INTEGER DEFAULT 0")]:
        try:
            if not re.match(r'^[a-zA-Z_][a-zA-Z0-9_]*$', col):
                continue  # Skip unsafe column names
            conn.execute(f"ALTER TABLE campaign_emails ADD COLUMN {col} {typ}")
            conn.commit()
        except Exception:
            pass
    campaign_row = conn.execute("SELECT * FROM campaigns WHERE campaign_id = ? AND user_id = ?",
                                 (campaign_id, user_id)).fetchone()
    if not campaign_row:
        conn.close()
        return RedirectResponse("/dashboard", status_code=303)
    campaign = dict(campaign_row)
    user_row = conn.execute("SELECT * FROM users WHERE user_id = ?", (user_id,)).fetchone()
    user = dict(user_row) if user_row else {}
    emails = [dict(r) for r in conn.execute(
        "SELECT * FROM campaign_emails WHERE campaign_id = ? ORDER BY sent_at DESC",
        (campaign_id,)).fetchall()]
    conn.close()

    weapon_count = campaign.get("premium_weapons", 0) or 0
    is_running = campaign.get("status", "") == "running"

    # Weapon tier badge
    if weapon_count >= 14:
        weapon_badge = '<span class="wb-god">&#x1F451; GOD MODE V4 &#x2014; 15/15 WEAPONS ACTIVE</span>'
        weapon_class = "god"
    elif weapon_count >= 10:
        weapon_badge = f'<span class="wb-emperor">&#x1F934; EMPEROR &#x2014; {weapon_count}/12 WEAPONS ACTIVE</span>'
        weapon_class = "emperor"
    elif weapon_count >= 3:
        weapon_badge = f'<span class="wb-pro">&#x1F3C6; PRO HUNTER V2 &#x2014; {weapon_count}/5 WEAPONS ACTIVE</span>'
        weapon_class = "pro"
    elif weapon_count >= 1:
        weapon_badge = f'<span class="wb-starter">âš¡ {weapon_count} WEAPON(S) ACTIVE</span>'
        weapon_class = "starter"
    else:
        weapon_badge = '<span class="wb-none">&#x1F6AB; NO WEAPONS &#8212; Visit Premium Services to arm up</span>'
        weapon_class = "none"

    # Progress bar
    progress_pct = min(100, int((weapon_count / 15) * 100))

    # Stats
    sent = sum(1 for e in emails if e.get("status") == "sent")
    failed = sum(1 for e in emails if e.get("status") in ("pending", "brevo_failed", "gmail_failed"))
    total = len(emails)
    followups = sum(1 for e in emails if e.get("followup_scheduled"))

    # ---- Competition Radar ----
    comp_rows = ""
    for e in emails:
        cs = e.get("competition_score") or 0
        if cs:
            heat = "&#x1F525; HOT" if cs >= 80 else "&#x26A1; GOOD" if cs >= 70 else "&#x1F976; COLD"
            heat_cls = "hot" if cs >= 80 else "good" if cs >= 70 else "cold"
            comp_rows += f'''<div class="comp-card {heat_cls}">
<span class="comp-company">{e.get("company_name","?")}</span>
<span class="comp-role">{e.get("job_title","")}</span>
<div class="comp-score-bar"><div class="comp-fill" style="width:{cs}%;"></div></div>
<span class="comp-heat {heat_cls}">{heat} Â· {cs}%</span>
</div>'''

    # ---- LinkedIn War Station ----
    linkedin_rows = ""
    for e in emails:
        lm = (e.get("linkedin_message") or "").strip()
        if lm:
            linkedin_rows += f'''<div class="wr-card">
<div class="wr-card-head"><span class="wr-company">{e.get("company_name","?")}</span><span class="wr-role">{e.get("job_title","")}</span></div>
<div class="wr-card-body terminal">{lm}</div>
<button class="wr-btn-copy" onclick="copyText(this)"><span class="copy-icon">ðŸ"‹</span> COPY TO CLIPBOARD</button>
</div>'''

    # ---- Interview Prep Armory ----
    interview_rows = ""
    for e in emails:
        ip = (e.get("interview_prep") or "").strip()
        if ip:
            escaped = ip.replace("&", "&amp;").replace("<", "&lt;").replace(">", "&gt;")
            interview_rows += f'''<div class="wr-card">
<div class="wr-card-head"><span class="wr-company">{e.get("company_name","?")}</span><span class="wr-role">{e.get("job_title","")}</span></div>
<div class="wr-card-body terminal" style="white-space:pre-wrap;">{escaped}</div>
<button class="wr-btn-copy" onclick="copyText(this)"><span class="copy-icon">ðŸ"‹</span> COPY GUIDE</button>
</div>'''

    # ---- Cover Letter Library ----
    cover_rows = ""
    for e in emails[:20]:
        status_label = "SENT" if e.get("status") == "sent" else "FAILED"
        status_cls = "sent" if e.get("status") == "sent" else "failed"
        ch = (e.get("cover_html") or "").strip()
        has_preview = "true" if ch else "false"
        cover_rows += f'''<div class="wr-card" data-has-preview="{has_preview}">
<div class="wr-card-head"><span class="wr-company">{e.get("company_name","?")}</span><span class="wr-role">{e.get("job_title","")}</span><span class="wr-status {status_cls}">{status_label}</span></div>
<div class="wr-card-body terminal cover-preview" style="display:{"block" if ch else "none"};max-height:160px;overflow:hidden;">{ch[:800]}</div>
<button class="wr-btn-copy" onclick="copyHtml(this)"><span class="copy-icon">ðŸ"‹</span> COPY HTML</button>
</div>'''

    # ---- Action Items ----
    actions = []
    st = campaign.get("status", "")
    if st == "completed":
        actions = [
            ('CRITICAL', 'ðŸ"¬ Send follow-ups to non-responsive companies (Day 3/7/14)', 'crit'),
            ('HIGH', 'ðŸ"- Send LinkedIn connection requests (open LinkedIn Station below)', 'high'),
            ('HIGH', 'ðŸŽTMï ̧ Practice interview questions per company (open Armory below)', 'high'),
            ('MED', 'ðŸ"Š Launch a new campaign targeting different locations/roles', 'med'),
        ]
    elif st == "running":
        actions = [('INFO', 'â3 Campaign is actively sending â€" this page auto-refreshes', 'info')]
    elif st == "failed":
        actions = [('CRITICAL', 'ðŸ"" Campaign failed â€" check error details and retry', 'crit')]
    else:
        actions = [('INFO', 'â3 Campaign pending â€" refresh when started', 'info')]
    action_html = "".join(f'<div class="action-item action-{sev}"><span class="action-badge action-badge-{sev}">{label}</span>{act}</div>' for label, act, sev in actions)

    # Auto-refresh for running campaigns
    auto_refresh = '<meta http-equiv="refresh" content="15">' if is_running else ''

    content = f'''<style>
.war-body{{background:#05050a;color:#c0c0c0;font-family:"Inter",sans-serif;--matrix:#00ff41;--matrix-dim:rgba(0,255,65,.15);--blue:#3b82f6;--gold:#f59e0b;--red:#ef4444;--pink:#ec4899;--cyan:#06b6d4;}}
.war-body *{{box-sizing:border-box;}}
/* Scanline overlay */
.war-body::after{{content:"";position:fixed;top:0;left:0;width:100%;height:100%;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,.03) 2px,rgba(0,0,0,.03) 4px);pointer-events:none;z-index:9999;}}
/* Binary rain corner */
.binary-rain{{position:absolute;top:8px;right:12px;font-family:"Courier New",monospace;font-size:10px;color:rgba(0,255,65,.12);line-height:1.2;pointer-events:none;z-index:1;animation:rainDrop 3s ease-in-out infinite;}}
@keyframes rainDrop{{0%,100%{{opacity:.08;}}50%{{opacity:.2;}}}}
/* God Mode pulse */
@keyframes godPulse{{0%,100%{{box-shadow:0 0 8px rgba(236,72,153,.3),0 0 20px rgba(236,72,153,.1);}}50%{{box-shadow:0 0 20px rgba(236,72,153,.6),0 0 40px rgba(236,72,153,.25);}}}}
.wb-god{{display:inline-block;padding:8px 20px;border-radius:8px;font-size:13px;font-weight:800;letter-spacing:1px;background:linear-gradient(135deg,rgba(236,72,153,.2),rgba(139,92,246,.2));border:1px solid rgba(236,72,153,.4);color:#f9a8d4;animation:godPulse 2s infinite;}}
.wb-emperor{{display:inline-block;padding:8px 20px;border-radius:8px;font-size:13px;font-weight:700;background:linear-gradient(135deg,rgba(59,130,246,.2),rgba(6,182,212,.2));border:1px solid rgba(59,130,246,.4);color:#93c5fd;}}
.wb-pro{{display:inline-block;padding:8px 20px;border-radius:8px;font-size:13px;font-weight:700;background:rgba(245,158,11,.15);border:1px solid rgba(245,158,11,.3);color:#fcd34d;}}
.wb-starter{{display:inline-block;padding:6px 14px;border-radius:8px;font-size:12px;font-weight:600;background:rgba(34,197,94,.1);border:1px solid rgba(34,197,94,.25);color:#86efac;}}
.wb-none{{display:inline-block;padding:6px 14px;border-radius:8px;font-size:12px;color:#64748b;border:1px dashed rgba(255,255,255,.1);}}

/* Header */
.wr-header{{background:linear-gradient(180deg,rgba(10,10,20,.98),rgba(5,5,10,.98));border:1px solid rgba(0,255,65,.1);border-radius:12px;padding:24px 28px 18px;margin-bottom:20px;position:relative;}}
.wr-header .wr-title{{font-size:20px;font-weight:800;color:var(--matrix);letter-spacing:1px;font-family:"Courier New",monospace;}}
.wr-header .wr-sub{{font-size:11px;color:#64748b;margin-top:4px;font-family:"Courier New",monospace;}}
.wr-header .wr-progress{{margin-top:12px;height:3px;background:rgba(255,255,255,.06);border-radius:2px;overflow:hidden;}}
.wr-header .wr-progress-fill{{height:100%;background:linear-gradient(90deg,var(--matrix),var(--cyan),var(--blue),var(--pink));border-radius:2px;transition:width .6s;width:{progress_pct}%;}}
.wr-header .wr-badge-row{{margin-top:12px;}}

/* Stats */
.wr-stat-grid{{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:10px;margin-bottom:20px;}}
.wr-stat{{background:rgba(10,10,20,.95);border:1px solid rgba(0,255,65,.08);border-radius:10px;padding:14px;text-align:center;transition:all .2s;}}
.wr-stat:hover{{border-color:var(--matrix-dim);box-shadow:0 0 12px var(--matrix-dim);}}
.wr-stat .wr-stat-num{{font-size:26px;font-weight:800;color:var(--matrix);font-family:"Courier New",monospace;}}
.wr-stat .wr-stat-lbl{{font-size:10px;color:#52525b;text-transform:uppercase;letter-spacing:1.5px;margin-top:4px;}}
.wr-stat.danger .wr-stat-num{{color:var(--red);}}
.wr-stat.warn .wr-stat-num{{color:var(--gold);}}

/* Section headers - military brackets */
.wr-section{{font-size:14px;font-weight:700;color:var(--matrix);margin:28px 0 14px;font-family:"Courier New",monospace;letter-spacing:1px;}}
.wr-section::before{{content:"[ ";color:rgba(0,255,65,.4);}}
.wr-section::after{{content:" ]";color:rgba(0,255,65,.4);}}

/* Cards */
.wr-grid{{display:grid;grid-template-columns:repeat(auto-fill,minmax(380px,1fr));gap:12px;margin-bottom:16px;}}
.wr-card{{background:rgba(10,10,20,.9);border:1px solid rgba(255,255,255,.04);border-radius:10px;padding:14px;transition:all .2s;}}
.wr-card:hover{{border-color:var(--matrix-dim);box-shadow:0 0 16px rgba(0,255,65,.06);}}
.wr-card-head{{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;flex-wrap:wrap;gap:6px;}}
.wr-company{{font-size:13px;font-weight:600;color:#d4d4d8;}}
.wr-role{{font-size:10px;color:#52525b;}}
.wr-status{{font-size:9px;padding:2px 8px;border-radius:8px;font-weight:700;letter-spacing:.5px;}}
.wr-status.sent{{background:rgba(0,255,65,.12);color:var(--matrix);}}
.wr-status.failed{{background:rgba(239,68,68,.12);color:var(--red);}}
.wr-card-body{{font-size:11px;color:#71717a;line-height:1.6;margin-bottom:10px;max-height:180px;overflow-y:auto;scrollbar-width:thin;scrollbar-color:rgba(0,255,65,.2) transparent;}}
.wr-card-body.terminal{{font-family:"Courier New",monospace;color:#a3e635;background:rgba(0,0,0,.3);padding:10px;border-radius:6px;border-left:2px solid var(--matrix-dim);}}
.cover-preview{{}}
.wr-btn-copy{{background:rgba(0,255,65,.08);color:var(--matrix);border:1px solid rgba(0,255,65,.2);padding:5px 12px;border-radius:5px;font-size:10px;font-weight:700;cursor:pointer;transition:all .2s;font-family:"Courier New",monospace;letter-spacing:.5px;}}
.wr-btn-copy:hover{{background:rgba(0,255,65,.16);border-color:var(--matrix);box-shadow:0 0 8px var(--matrix-dim);}}
.wr-btn-copy.copied{{background:rgba(0,255,65,.2);color:#000;}}

/* Competition Radar */
.comp-grid{{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:10px;margin-bottom:16px;}}
.comp-card{{background:rgba(10,10,20,.9);border:1px solid rgba(255,255,255,.04);border-radius:10px;padding:14px;display:flex;align-items:center;gap:12px;transition:all .2s;}}
.comp-card:hover{{border-color:rgba(0,255,65,.1);}}
.comp-card.hot{{border-left:3px solid var(--red);}}
.comp-card.good{{border-left:3px solid var(--gold);}}
.comp-card.cold{{border-left:3px solid var(--cyan);}}
.comp-company{{font-size:12px;font-weight:600;color:#d4d4d8;min-width:100px;}}
.comp-role{{font-size:10px;color:#52525b;flex:1;}}
.comp-score-bar{{flex:1;height:4px;background:rgba(255,255,255,.06);border-radius:2px;overflow:hidden;}}
.comp-fill{{height:100%;border-radius:2px;transition:width .5s;}}
.comp-card.hot .comp-fill{{background:linear-gradient(90deg,var(--red),#f97316);}}
.comp-card.good .comp-fill{{background:linear-gradient(90deg,var(--gold),#a3e635);}}
.comp-card.cold .comp-fill{{background:linear-gradient(90deg,var(--cyan),var(--blue));}}
.comp-heat{{font-size:10px;font-weight:700;min-width:80px;text-align:right;}}
.comp-heat.hot{{color:var(--red);}}
.comp-heat.good{{color:var(--gold);}}
.comp-heat.cold{{color:var(--cyan);}}

/* Action items */
.action-item{{background:rgba(10,10,20,.9);border:1px solid rgba(255,255,255,.04);border-radius:10px;padding:12px 16px;margin-bottom:8px;font-size:13px;color:#d4d4d8;display:flex;align-items:center;gap:10px;transition:all .2s;}}
.action-item:hover{{border-color:rgba(0,255,65,.08);}}
.action-badge{{font-size:9px;font-weight:800;padding:3px 10px;border-radius:4px;letter-spacing:.8px;min-width:70px;text-align:center;font-family:"Courier New",monospace;}}
.action-badge-crit{{background:rgba(239,68,68,.15);color:var(--red);border:1px solid rgba(239,68,68,.3);}}
.action-badge-high{{background:rgba(245,158,11,.15);color:var(--gold);border:1px solid rgba(245,158,11,.3);}}
.action-badge-med{{background:rgba(59,130,246,.15);color:var(--blue);border:1px solid rgba(59,130,246,.3);}}
.action-badge-info{{background:rgba(0,255,65,.1);color:var(--matrix);border:1px solid var(--matrix-dim);}}
.action-crit{{border-left:3px solid var(--red);}}
.action-high{{border-left:3px solid var(--gold);}}
.action-med{{border-left:3px solid var(--blue);}}
.action-info{{border-left:3px solid var(--matrix);}}

/* Salary intel */
.sal-grid{{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:10px;margin-bottom:16px;}}
.sal-box{{background:rgba(10,10,20,.9);border:1px solid rgba(0,255,65,.06);border-radius:10px;padding:14px;text-align:center;}}
.sal-box .sal-range{{font-size:16px;font-weight:800;color:var(--matrix);font-family:"Courier New",monospace;}}
.sal-box .sal-region{{font-size:11px;color:#52525b;margin-top:4px;}}
.sal-box .sal-intel{{font-size:9px;color:#3f3f46;margin-top:4px;}}

/* Empty state */
.wr-empty{{text-align:center;padding:40px 20px;color:#3f3f46;}}
.wr-empty .wr-empty-icon{{font-size:36px;margin-bottom:10px;opacity:.5;}}
.wr-empty .wr-empty-text{{font-size:12px;font-family:"Courier New",monospace;}}

@media(max-width:768px){{.wr-grid,.comp-grid{{grid-template-columns:1fr;}}.wr-stat-grid{{grid-template-columns:repeat(3,1fr);}}}}
</style>
{auto_refresh}
<div class="war-body">
