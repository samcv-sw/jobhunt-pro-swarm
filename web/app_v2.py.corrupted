@app.get("/api/v1/funnel-analytics")
async def api_funnel_analytics(days: int = None):
    """Enhanced funnel analytics with optional date range filter."""
    conn = None
    try:
        conn = get_db()
        conn.row_factory = sqlite3.Row

        now = int(_time.time())
        where_clause = ""
        params = ()

        if days:
            cutoff = now - (days * 86400)
            where_clause = "WHERE sent_at >= ?"
            params = (cutoff,)

        c = conn.execute(f"SELECT COUNT(*) as cnt FROM applications {where_clause}", params)
        applied = c.fetchone()['cnt']

        c = conn.execute(f"SELECT COUNT(*) as cnt FROM applications {where_clause} AND responded = 1", params)
        responded = c.fetchone()['cnt']

        c = conn.execute(f"SELECT COUNT(*) as cnt FROM applications {where_clause} AND response_type = 'interview'", params)
        interview = c.fetchone()['cnt']

        c = conn.execute(f"SELECT COUNT(*) as cnt FROM applications {where_clause} AND response_type IN ('offer','hired')", params)
        offer = c.fetchone()['cnt']

        c = conn.execute(f"SELECT COUNT(*) as cnt FROM applications {where_clause} AND status = 'hired'", params)
        hired = c.fetchone()['cnt']

        # Estimate viewed: all that got a response + a portion of unresponded
        viewed = min(applied, int(responded * 2.2)) if responded > 0 else max(applied // 4, 0)

        return {
            "applied": applied,
            "viewed": viewed,
            "responded": responded,
            "interview": interview,
            "offer": offer,
            "hired": hired,
            "period_days": days or "all"
        }
    finally:
        if conn:
            conn.close()


