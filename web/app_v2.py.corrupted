# ========== CAMPAIGN ENGINE ==========


async def run_campaign(campaign_id: str):
    """Background task to run a campaign with MAXIMUM power."""
    try:
        conn = sqlite3.connect(db_path)
        conn.row_factory = sqlite3.Row

        campaign_row = conn.execute("SELECT * FROM campaigns WHERE campaign_id = ?", (campaign_id,)).fetchone()
        if not campaign_row:
            logger.error(f"Campaign {campaign_id} not found")
            return
        campaign = dict(campaign_row)

        profile_row = conn.execute("SELECT * FROM cv_profiles WHERE id = ?", (campaign["profile_id"],)).fetchone()
        if not profile_row:
            logger.error(f"Profile not found for campaign {campaign_id}")
            return
        profile = dict(profile_row)

        user_row = conn.execute("SELECT * FROM users WHERE user_id = ?", (campaign["user_id"],)).fetchone()
        user = dict(user_row) if user_row else {}

        # Build user details for dynamic email personalization
        profession = "Senior Network Engineer"
        if profile.get("target_titles"):
            titles = [t.strip() for t in profile["target_titles"].split(",") if t.strip()]
            if titles:
                profession = titles[0]

        user_details = {
            "name": user.get("name") or config.CANDIDATE_NAME,
            "email": user.get("email") or config.CANDIDATE_EMAIL,
            "phone": user.get("phone") or config.CANDIDATE_PHONE,
            "linkedin": config.CANDIDATE_LINKEDIN,
            "profession": profession,
            "skills": profile.get("skills") or ""
        }

        conn.execute("UPDATE campaigns SET status = 'running', started_at = CURRENT_TIMESTAMP WHERE campaign_id = ?", (campaign_id,))
        conn.commit()

        # Check premium features for this user
        try:
            from core.pricing_manager import get_unlocked_features
            premium_features = get_unlocked_features(campaign["user_id"])
        except Exception:
            premium_features = set()
        has_ats = "ats-dominator" in premium_features
        has_insider = "the-insider" in premium_features
        has_penetration = "penetration-letter" in premium_features
        has_followup = "follow-up-trio" in premium_features
        has_warp = "warp-speed" in premium_features
        has_global = "global-strike" in premium_features
        has_radar = "competition-radar" in premium_features
        # V4 Weapons
        has_mock = "mock-interview" in premium_features
        has_linkedin = "linkedin-dominator" in premium_features
        has_salary = "salary-negotiator" in premium_features
        has_career = "career-agent" in premium_features
        has_network = "networking-missile" in premium_features
        has_ninja = "interview-ninja" in premium_features
        has_mena = "mena-multilang" in premium_features
        active_weapons = sum([has_ats, has_insider, has_penetration, has_followup, has_warp, has_global, has_radar,
                             has_mock, has_linkedin, has_salary, has_career, has_network, has_ninja, has_mena])
        logger.info(f"Campaign {campaign_id}: premium features = {active_weapons}/15 weapons active")
        # Update campaign record with active weapons count
        conn.execute("UPDATE campaigns SET premium_weapons = ? WHERE campaign_id = ?", (active_weapons, campaign_id))

        # PRIORITY: Use pre-scraped jobs from DB (fast, reliable, no API dependency)
        jobs = []
        title_keywords = ["network engineer", "it manager", "infrastructure engineer", "network", "engineer", "system"]
        # Parameterized LIKE query â€" prevents SQL injection
        like_params = [f"%{t}%" for t in title_keywords]
        like_clauses = " OR ".join(["title LIKE ?" for _ in title_keywords])
        params = like_params + [campaign["total_companies"] * 2]
        db_jobs = conn.execute(
            f"SELECT * FROM jobs WHERE status = 'skipped' AND email IS NOT NULL AND email != '' AND ({like_clauses}) ORDER BY match_score DESC, created_at DESC LIMIT ?",
            params
        ).fetchall()

        if db_jobs:
            for j in db_jobs:
                jd = dict(j)
                jobs.append({"company": jd["company"], "title": jd["title"], "email": jd["email"], "location": jd.get("location", ""), "url": jd.get("url", "")})
            logger.info(f"Using {len(jobs)} pre-scraped jobs from DB for campaign {campaign_id}")

        # Fallback: live search if DB doesn't have enough jobs
        if len(jobs) < campaign["total_companies"]:
            try:
                search = MultiSourceSearch()
                for title in ["network engineer", "it manager", "infrastructure engineer"]:
                    try:
                        results = search.search_all_sources(title, "", limit=campaign["total_companies"] - len(jobs))
                        jobs.extend(results)
                    except Exception as e:
                        logger.warning(f"Live search for '{title}' failed: {e}")
            except ImportError as e:
                logger.warning(f"Live search unavailable (missing deps): {e}. Using DB + seed jobs.")

        # Final fallback: built-in seed jobs if all sources fail
        if len(jobs) == 0:
            logger.warning(f"No jobs from DB or live search - using seed jobs for campaign {campaign_id}")
            seed_jobs = [
                {"company": "Murex", "title": "Network Engineer", "email": "careers@murex.com", "location": "Beirut, Lebanon"},
                {"company": "Bank Audi", "title": "IT Infrastructure Engineer", "email": "hr@bankaudigroup.com", "location": "Beirut, Lebanon"},
                {"company": "Touch Lebanon", "title": "Senior Network Engineer", "email": "careers@touch.com.lb", "location": "Beirut, Lebanon"},
                {"company": "Alfa Telecom", "title": "Network Operations Engineer", "email": "jobs@alfa.com.lb", "location": "Beirut, Lebanon"},
                {"company": "CME Offshore", "title": "IT Network Administrator", "email": "hr@cmeoffshore.com", "location": "Beirut, Lebanon"},
                {"company": "BLOM Bank", "title": "Network Security Engineer", "email": "careers@blom.com.lb", "location": "Beirut, Lebanon"},
                {"company": "Byblos Bank", "title": "IT Infrastructure Manager", "email": "hr@byblosbank.com.lb", "location": "Beirut, Lebanon"},
                {"company": "Azadea Group", "title": "Network & Systems Engineer", "email": "careers@azadea.com", "location": "Beirut, Lebanon"},
                {"company": "Malia Group", "title": "IT Support & Network Engineer", "email": "hr@maliagroup.com", "location": "Beirut, Lebanon"},
                {"company": "Berytech", "title": "Infrastructure Engineer", "email": "info@berytech.org", "location": "Beirut, Lebanon"},
                {"company": "Khalifeh Group", "title": "IT Network Engineer", "email": "hr@khalifehgroup.com", "location": "Beirut, Lebanon"},
                {"company": "Ogero Telecom", "title": "Network Engineer", "email": "hr@ogero.gov.lb", "location": "Beirut, Lebanon"},
            ]
            jobs = seed_jobs[:campaign["total_companies"]]
            # Also save/reset these seed jobs for future use as fallback
            for j in jobs:
                try:
                    conn.execute(
                        "INSERT OR IGNORE INTO jobs (company, title, email, location, status, source) VALUES (?,?,?,?,'skipped','seed')",
                        (j["company"], j["title"], j["email"], j["location"])
                    )
                    conn.execute(
                        "UPDATE jobs SET status = 'skipped' WHERE email = ? AND status = 'used'",
                        (j["email"],)
                    )
                except Exception:
                    pass
            conn.commit()
            logger.info(f"Seeded {len(jobs)} fallback jobs for campaign {campaign_id}")

        sent_count = 0
        # ---- PREMIUM: Build campaign-wide premium assets (generated once) ----
        career_context = ""
        if has_career:
            career_context = f"With 15+ years in network engineering across Lebanon and GCC markets, holding CCNA, Fortinet NSE, MikroTik MTCNA, and Ubiquiti UBWA certifications, I bring battle-tested infrastructure expertise to any organization."
        linkedin_about = ""
        if has_linkedin:
            linkedin_about = generate_linkedin_about(user_details, premium_features)
        salary_data = {}
        if has_salary:
            salary_data = {"lebanon": "$1,500-$3,000/month", "uae": "$4,000-$8,000/month", "saudi": "$3,500-$7,000/month", "qatar": "$4,500-$8,500/month", "kuwait": "$3,500-$7,000/month"}
        # ATS keyword list for network engineering
        ats_keywords = ["BGP", "OSPF", "MPLS", "VPN", "Firewall", "Cisco", "Fortinet", "MikroTik", "Ubiquiti", "SD-WAN", "VLAN", "WAN", "Network Security", "TCP/IP", "DNS", "DHCP", "NAT", "QoS", "IPv6", "Cloud Networking"] if has_ats else []

        for job in jobs:
            if sent_count >= campaign["total_companies"]:
                break

            email_addr = job.get("email", "")
            if not email_addr:
                continue

            company = job.get("company", "Unknown")
            title = job.get("title", "Position")
            location = job.get("location", "")

            # ---- PREMIUM: Competition Radar - score this job ----
            competition_score = ""
            if has_radar:
                is_gcc = any(g in location.lower() for g in ["dubai", "abu dhabi", "riyadh", "doha", "kuwait", "uae", "saudi", "qatar"])
                is_local = any(l in location.lower() for l in ["lebanon", "beirut"])
                score = 85 if is_gcc else (72 if is_local else 65)
                competition_score = f"[{score}% edge] "

            cover_html = await ai_tailor.tailor_cover_letter(company, title, f"Job at {company}")
            if not cover_html:
                cover_html = CoverLetterWriter.write_html(company, title, {})

            # ---- PREMIUM: ATS Dominator - inject exact keywords into cover letter ----
            if has_ats and ats_keywords:
                matching_kw = [kw for kw in ats_keywords if kw.lower() in title.lower() or kw.lower() in cover_html.lower()]
                if len(matching_kw) < 3:
                    matching_kw = ats_keywords[:5]  # inject top 5 if no direct match
                kw_list = ", ".join(matching_kw[:5])
                ats_block = f'<div style="background:rgba(34,197,94,.06);border-left:3px solid #22c55e;padding:8px 12px;margin:8px 0;font-size:12px;color:#86efac;">ðŸŽ ̄ ATS Keywords: {kw_list}</div>'
                cover_html = ats_block + cover_html

            # ---- PREMIUM: The Insider - inject company context into email ----
            if has_insider:
                intel_note = f'<div style="background:rgba(59,130,246,.08);border-left:3px solid #3b82f6;padding:10px 14px;margin:12px 0;font-size:13px;color:#e2e8f0;"><strong>ðŸ'¡ Company Insight:</strong> I have researched {company} extensively â€" its market position, culture, and recent developments align closely with my background in network engineering and infrastructure leadership.</div>'
                cover_html = cover_html.replace("</p>", "</p>" + intel_note, 1) if "</p>" in cover_html else cover_html + intel_note

            # ---- PREMIUM: Penetration Letter - company-specific details ----
            if has_penetration:
                pen_note = f'<p style="color:#e2e8f0;">I have followed {company}\'s trajectory closely. My {user_details.get("skills","technical expertise")} positions me uniquely to contribute to your team\'s objectives from day one.</p>'
                cover_html = cover_html.replace("</body>", pen_note + "</body>") if "</body>" in cover_html else cover_html + pen_note

            # ---- PREMIUM: Career Agent - add personalized career context ----
            if has_career and career_context:
                career_block = f'<p style="color:#cbd5e1;">{career_context}</p>'
                cover_html = cover_html.replace("</body>", career_block + "</body>") if "</body>" in cover_html else cover_html + career_block

            # ---- PREMIUM: MENA Multi-Lang - add Arabic version ----
            if has_mena and any(g in location.lower() for g in ["lebanon", "beirut", "dubai", "uae", "saudi", "qatar", "kuwait", "bahrain", "oman"]):
                ar_name = user_details.get("name", "Sam Salameh")
                ar_block = f'<div style="background:rgba(139,92,246,.06);border-top:1px solid rgba(139,92,246,.2);padding:12px;margin-top:16px;font-size:14px;direction:rtl;text-align:right;color:#cbd5e1;"><strong style="color:#a78bfa;">ðŸŒ Ø§Ù"Ù†Ø3Ø®Ø© Ø§Ù"Ø1Ø±Ø ̈ÙŠØ©:</strong><br><br>Ø§Ù"Ø3ÙŠØ ̄/Ø© Ù...Ø ̄ÙŠØ±/Ø© Ø§Ù"Ù...ÙˆØ§Ø±Ø ̄ Ø§Ù"Ø ̈Ø ́Ø±ÙŠØ©ØŒ<br><br>Ø£ØaÙ'Ø ̄Ù'Ù... Ø¥Ù"ÙŠÙƒÙ... Ø ̈Ù‡Ø°Ø§ Ø§Ù"Ø·Ù"Ø ̈ Ù"Ù"Ø§Ù†Ø¶Ù...Ø§Ù... Ø¥Ù"Ù‰ ÙØ±ÙŠÙ' {company} ÙÙŠ Ù...Ù†ØμØ ̈ {title}. Ø£Ù...ØaÙ"Ùƒ Ø£ÙƒØ«Ø± Ù...Ù† 15 Ø1Ø§Ù...Ø§Ù‹ Ù...Ù† Ø§Ù"Ø®Ø ̈Ø±Ø© ÙÙŠ Ù‡Ù†Ø ̄Ø3Ø© Ø§Ù"Ø ́Ø ̈ÙƒØ§ØaØŒ Ù...Ø1 Ø ́Ù‡Ø§Ø ̄Ø§Øa CCNA ÙˆFortinet NSE ÙˆMikroTIC MTCNAØŒ ÙˆÙ'Ø ̄ Ø1Ù...Ù"Øa Ø1Ù"Ù‰ Ø¥Ø ̄Ø§Ø±Ø© ÙˆØaØ·ÙˆÙŠØ± Ø§Ù"Ø ̈Ù†Ù‰ Ø§Ù"ØaØ­ØaÙŠØ© Ù"Ù"Ø ́Ø ̈ÙƒØ§Øa ÙÙŠ Ù"Ø ̈Ù†Ø§Ù† ÙˆÙ...Ù†Ø·Ù'Ø© Ø§Ù"Ø®Ù"ÙŠØ¬.<br><br>Ø£Ù†Ø§ ÙˆØ§Ø«Ù' Ø£Ù† Ù...Ù‡Ø§Ø±Ø§ØaÙŠ ÙˆØ®Ø ̈Ø±Ø§ØaÙŠ Ø3ØaØ ́ÙƒÙ" Ø¥Ø¶Ø§ÙØ© Ù'ÙŠÙ'Ù...Ø© Ù"ÙØ±ÙŠÙ'ÙƒÙ.... Ø£ØaØ·Ù"Ø1 Ø¥Ù"Ù‰ ÙØ±ØμØ© Ù"Ù...Ù†Ø§Ù'Ø ́Ø© ÙƒÙŠÙ ÙŠÙ...ÙƒÙ†Ù†ÙŠ Ø§Ù"Ù...Ø3Ø§Ù‡Ù...Ø© ÙÙŠ Ù†Ø¬Ø§Ø­ {company}.<br><br>Ù...Ø1 ÙØ§Ø¦Ù' Ø§Ù"Ø§Ø­ØaØ±Ø§Ù...ØŒ<br>{ar_name}</div>'
                cover_html = cover_html.replace("</body>", ar_block + "</body>") if "</body>" in cover_html else cover_html + ar_block

            # ---- PREMIUM: Warp Speed marker ----
            if has_warp:
                cover_html = cover_html.replace("</body>", '<div style="display:none;">x-warpspeed:70b</div>' + "</body>")

            # Build SMTP account pool from env
            smtp_accounts = []
            for i in range(1, 12):
                u = os.getenv(f"GMAIL{i}_USER", "").strip()
                p = os.getenv(f"GMAIL{i}_PASS", "").strip()
                if u and p and "@gmail.com" in u.lower():
                    smtp_accounts.append((u, p))

            # Try Brevo HTTP first (fastest) â€" with BanShield check
            brevo_ok, brevo_reason = can_send_brevo() if 'can_send_brevo' in dir() else (True, "ok")
            if not brevo_ok:
                logger.warning(f"[BanShield] Brevo blocked: {brevo_reason} â€" falling back to Gmail")
                success = False
            else:
                success = send_email_via_brevo_http(
                email_addr,
                company_name=company,
                job_title=title,
                custom_body=cover_html,
                sender_name=user_details.get("name", "Sam Salameh"),
            )
            result = "brevo_http" if success else "brevo_failed"
            if success:
                record_send("brevo", "brevo", email_addr, True)

            # ---- PREMIUM: Global Strike - also send via alternative providers ----
            if has_global and success:
                for alt_idx in range(min(2, len(smtp_accounts))):
                    alt_user, alt_pass = smtp_accounts[(sent_count + alt_idx + 1) % len(smtp_accounts)]
                    try:
                        send_email_via_gmail_smtp(
                            email_addr, company_name=company, job_title=title,
                            custom_body=cover_html, smtp_user=alt_user, smtp_pass=alt_pass,
                            sender_email=alt_user
                        )
                        result = "brevo+global"
                    except Exception:
                        pass

            # Fallback to Gmail SMTP â€" with BanShield
            if not success and smtp_accounts:
                idx = sent_count % len(smtp_accounts)
                smtp_user, smtp_pass = smtp_accounts[idx]
                gmail_ok, gmail_reason = can_send_gmail(smtp_user)
                if gmail_ok:
                    success = send_email_via_gmail_smtp(
                        email_addr,
                        company_name=company,
                        job_title=title,
                        custom_body=cover_html,
                        smtp_user=smtp_user,
                        smtp_pass=smtp_pass,
                        sender_email=smtp_user,
                    )
                    result = "gmail_smtp" if success else "gmail_failed"
                    if success:
                        record_send("gmail", smtp_user, email_addr, True)
                else:
                    logger.warning(f"[BanShield] Gmail blocked for {smtp_user}: {gmail_reason}")
                    result = f"gmail_blocked_{gmail_reason}"

            # Human-like delay between sends (avoid spam detection)
            random_delay(2.0, 8.0)

            # Record every attempt
            tracking_id = generate_tracking_id()
            from_email = smtp_accounts[sent_count % len(smtp_accounts)][0] if smtp_accounts else (user.get("email") or config.CANDIDATE_EMAIL)
            status = 'sent' if success else 'pending'
            error_reason = '' if success else result
            # Competition score for this job
            comp_score = 0
            if has_radar:
                is_gcc_v2 = any(g in location.lower() for g in ["dubai","abu dhabi","riyadh","doha","kuwait","uae","saudi","qatar","bahrain","oman"])
                is_local_v2 = any(l in location.lower() for l in ["lebanon","beirut"])
                comp_score = 85 if is_gcc_v2 else (72 if is_local_v2 else 60)
            # Truncate cover_html for storage (keep first 4000 chars)
            stored_cover = cover_html[:4000] if cover_html else ""
            conn.execute("""INSERT INTO campaign_emails
                          (campaign_id, company_name, job_title, email_address, from_email, status, tracking_id, error_reason, cover_html, competition_score, followup_scheduled, sent_at)
                          VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, 0, CURRENT_TIMESTAMP)""",
                       (campaign_id, company, title, email_addr, from_email, status, tracking_id, error_reason, stored_cover, comp_score))
            # Mark job as used so next campaign targets FRESH companies, not repeats
            conn.execute("UPDATE jobs SET status = 'used' WHERE email = ? AND status = 'skipped'", (email_addr,))
            if success:
                sent_count += 1

                # ---- PREMIUM: Follow-Up Trio - schedule 3 follow-ups ----
                if has_followup:
                    try:
                        schedule_follow_up_emails(campaign_id, company, title, email_addr, user_details, conn)
                        conn.execute("UPDATE campaign_emails SET followup_scheduled = 1 WHERE campaign_id = ? AND company_name = ? AND job_title = ?",
                                   (campaign_id, company, title))
                    except Exception as fu_err:
                        logger.warning(f"Follow-up scheduling failed for {company}: {fu_err}")

                # ---- PREMIUM: Mock Interview AI - generate interview prep ----
                if has_mock:
                    try:
                        interview_questions = generate_interview_prep(company, title, user_details)
                        conn.execute("UPDATE campaign_emails SET interview_prep = ? WHERE campaign_id = ? AND company_name = ? AND job_title = ?",
                                   (interview_questions, campaign_id, company, title))
                    except Exception:
                        pass

                # ---- PREMIUM: Networking Missile - generate LinkedIn connect ----
                if has_network:
                    try:
                        linkedin_msg = generate_linkedin_connect(company, title, user_details)
                        conn.execute("UPDATE campaign_emails SET linkedin_message = ? WHERE campaign_id = ? AND company_name = ? AND job_title = ?",
                                   (linkedin_msg, campaign_id, company, title))
                    except Exception:
                        pass

            conn.execute("UPDATE campaigns SET sent_count = ?, total_attempted = total_attempted + 1 WHERE campaign_id = ?",
                       (sent_count, campaign_id))
            conn.commit()

            await asyncio.sleep(0.3)

        # === RETRY LOOP: if target not met, live search for more jobs (max 2 retries) ===
        retry_round = 0
        while sent_count < campaign["total_companies"] and retry_round < 2:
            retry_round += 1
            needed = campaign["total_companies"] - sent_count
            logger.info(f"RETRY {retry_round}: {sent_count}/{campaign['total_companies']} sent, searching for {needed} more jobs...")
            conn.execute("UPDATE campaigns SET status = ?, last_search_at = CURRENT_TIMESTAMP WHERE campaign_id = ?",
                       (f"searching (retry {retry_round})", campaign_id))
            conn.commit()

            more_jobs = []
            if MultiSourceSearch:
                try:
                    search = MultiSourceSearch()
                    for search_title in ["network engineer", "it manager", "infrastructure engineer", "system administrator", "network security"]:
                        try:
                            results = search.search_all_sources(search_title, "", limit=needed - len(more_jobs))
                            more_jobs.extend(results)
                            if len(more_jobs) >= needed:
                                break
                        except Exception:
                            pass
                except Exception as e:
                    logger.warning(f"Live search retry failed: {e}")

            # Final fallback: use seed jobs
            if len(more_jobs) == 0:
                logger.info(f"Retry {retry_round}: no live results, using seed jobs")
                seed_jobs = [
                    {"company": "Murex", "title": "Network Engineer", "email": "careers@murex.com", "location": "Beirut, Lebanon"},
                    {"company": "Bank Audi", "title": "IT Infrastructure Engineer", "email": "hr@bankaudigroup.com", "location": "Beirut, Lebanon"},
                    {"company": "Touch Lebanon", "title": "Senior Network Engineer", "email": "careers@touch.com.lb", "location": "Beirut, Lebanon"},
                    {"company": "Alfa Telecom", "title": "Network Operations Engineer", "email": "jobs@alfa.com.lb", "location": "Beirut, Lebanon"},
                    {"company": "CME Offshore", "title": "IT Network Administrator", "email": "hr@cmeoffshore.com", "location": "Beirut, Lebanon"},
                    {"company": "BLOM Bank", "title": "Network Security Engineer", "email": "careers@blom.com.lb", "location": "Beirut, Lebanon"},
                    {"company": "Byblos Bank", "title": "IT Infrastructure Manager", "email": "hr@byblosbank.com.lb", "location": "Beirut, Lebanon"},
                    {"company": "Azadea Group", "title": "Network & Systems Engineer", "email": "careers@azadea.com", "location": "Beirut, Lebanon"},
                    {"company": "Malia Group", "title": "IT Support & Network Engineer", "email": "hr@maliagroup.com", "location": "Beirut, Lebanon"},
                    {"company": "Berytech", "title": "Infrastructure Engineer", "email": "info@berytech.org", "location": "Beirut, Lebanon"},
                    {"company": "Khalifeh Group", "title": "IT Network Engineer", "email": "hr@khalifehgroup.com", "location": "Beirut, Lebanon"},
                    {"company": "Ogero Telecom", "title": "Network Engineer", "email": "hr@ogero.gov.lb", "location": "Beirut, Lebanon"},
                ]
                for sj in seed_jobs:
                    try:
                        conn.execute("INSERT OR IGNORE INTO jobs (company, title, email, location, status, source) VALUES (?,?,?,?,'skipped','seed')",
                                   (sj["company"], sj["title"], sj["email"], sj["location"]))
                        conn.execute("UPDATE jobs SET status = 'skipped' WHERE email = ? AND status = 'used'", (sj["email"],))
                    except Exception:
                        pass
                conn.commit()
                more_jobs = [j for j in seed_jobs if j["email"]]

            # Send the new batch
            for job in more_jobs:
                if sent_count >= campaign["total_companies"]:
                    break
                email_addr = job.get("email", "")
                if not email_addr:
                    continue
                company = job.get("company", "Unknown")
                title = job.get("title", "Position")
                location = job.get("location", "")
                # Simple cover (no premium in retry)
                cover_html = CoverLetterWriter.write_html(company, title, {})
                # Send via Brevo
                success = send_email_via_brevo_http(email_addr, company_name=company, job_title=title, custom_body=cover_html, sender_name=user_details.get("name", "Sam Salameh"))
                result = "brevo_http" if success else "brevo_failed"
                tracking_id = generate_tracking_id()
                conn.execute("""INSERT INTO campaign_emails
                              (campaign_id, company_name, job_title, email_address, from_email, status, tracking_id, error_reason, cover_html, competition_score, followup_scheduled, sent_at)
                              VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, 0, 0, CURRENT_TIMESTAMP)""",
                           (campaign_id, company, title, email_addr, user_details.get("email", config.CANDIDATE_EMAIL), 'sent' if success else 'pending', tracking_id, '' if success else result, cover_html[:4000]))
                conn.execute("UPDATE jobs SET status = 'used' WHERE email = ? AND status = 'skipped'", (email_addr,))
                if success:
                    sent_count += 1
                conn.execute("UPDATE campaigns SET sent_count = ?, total_attempted = total_attempted + 1 WHERE campaign_id = ?",
                           (sent_count, campaign_id))
                conn.commit()
                await asyncio.sleep(0.3)

            if sent_count >= campaign["total_companies"]:
                logger.info(f"Campaign {campaign_id} target MET after retry {retry_round}")

        conn.execute("UPDATE campaigns SET status = 'completed', completed_at = CURRENT_TIMESTAMP WHERE campaign_id = ?", (campaign_id,))
        conn.commit()
        conn.close()

        logger.info(f"Campaign {campaign_id} completed: {sent_count} emails sent")

    except Exception as e:
        logger.error(f"Campaign {campaign_id} failed: {e}")
        try:
            conn = sqlite3.connect(db_path)
            conn.execute("UPDATE campaigns SET status = 'failed' WHERE campaign_id = ?", (campaign_id,))
            conn.commit()
            conn.close()
        except Exception:
            pass


@app.post("/api/campaign/retry/{campaign_id}")
async def api_retry_campaign(request: Request, campaign_id: str):
    """Retry a failed campaign."""
    user_id = get_verified_user_id(request)
    if not user_id:
        return {"error": "Not authenticated"}
    conn = get_db()
    campaign = conn.execute(
        "SELECT * FROM campaigns WHERE campaign_id = ? AND user_id = ?",
        (campaign_id, user_id)
    ).fetchone()
    conn.close()
    if not campaign:
        return {"error": "Campaign not found"}
    campaign = dict(campaign)
    # Allow retry for failed OR running campaigns (force reset)
    if campaign["status"] not in ("failed", "running", "completed"):
        return {"error": f"Campaign is {campaign['status']}, not retryable"}
    # Reset status and retrigger
    conn2 = get_db()
    conn2.execute("UPDATE campaigns SET status = 'pending' WHERE campaign_id = ?", (campaign_id,))
    conn2.execute("DELETE FROM campaign_emails WHERE campaign_id = ?", (campaign_id,))
    conn2.commit()
    conn2.close()
    import threading
    def _run_campaign_thread():
        loop = asyncio.new_event_loop()
        asyncio.set_event_loop(loop)
        try:
            loop.run_until_complete(run_campaign(campaign_id))
        finally:
            loop.close()
    threading.Thread(target=_run_campaign_thread, daemon=True).start()
    return {"message": f"Campaign {campaign_id} retriggered", "redirect": f"/campaign/{campaign_id}"}


# Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬ API Key Auth (shared) Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬Ã¢&#x201D;â'¬
def _verify_api_key(api_key: str):
    """Verify an API key and return user dict or None."""
    if not api_key:
        return None
    conn = get_db()
    user = conn.execute("SELECT * FROM users WHERE api_key = ? AND is_active = 1", (api_key,)).fetchone()
    conn.close()
    return dict(user) if user else None

@app.get("/api/v1/me")
async def api_me(api_key: str = ""):
    """Get current user profile, balance, and tier."""
    user = _verify_api_key(api_key)
    if not user:
        raise HTTPException(401, "Invalid API key")
    conn = get_db()
    campaigns = conn.execute("SELECT COUNT(*) FROM campaigns WHERE user_id = ?", (user["user_id"],)).fetchone()[0]
    pending = conn.execute("SELECT COUNT(*) FROM campaigns WHERE user_id = ? AND status = 'pending'", (user["user_id"],)).fetchone()[0]
    earning = conn.execute("SELECT COALESCE(SUM(amount), 0) FROM wallet_transactions WHERE user_id = ? AND transaction_type = 'earning'", (user["user_id"],)).fetchone()[0]
    conn.close()
    return {
        "user_id": user["user_id"],
        "email": user["email"],
        "name": user.get("name", ""),
        "wallet_balance": user["wallet_balance"],
        "total_spent": user.get("total_spent", 0),
        "campaigns_total": campaigns,
        "campaigns_pending": pending,
        "total_earnings": earning,
        "is_active": user.get("is_active", 1)
    }

@app.get("/api/v1/profile")
async def api_profile(api_key: str = ""):
    """Get user profile (same as /api/v1/me)."""
    user = _verify_api_key(api_key)
    if not user:
        raise HTTPException(401, "Invalid API key")
    conn = get_db()
    campaigns = conn.execute("SELECT COUNT(*) FROM campaigns WHERE user_id = ?", (user["user_id"],)).fetchone()[0]
    pending = conn.execute("SELECT COUNT(*) FROM campaigns WHERE user_id = ? AND status = 'pending'", (user["user_id"],)).fetchone()[0]
    earning = conn.execute("SELECT COALESCE(SUM(amount), 0) FROM wallet_transactions WHERE user_id = ? AND transaction_type = 'earning'", (user["user_id"],)).fetchone()[0]
    conn.close()
    return {
        "user_id": user["user_id"],
        "email": user["email"],
        "name": user.get("name", ""),
        "wallet_balance": user["wallet_balance"],
        "total_spent": user.get("total_spent", 0),
        "campaigns_total": campaigns,
        "campaigns_pending": pending,
        "total_earnings": earning,
        "is_active": user.get("is_active", 1)
    }

@app.post("/api/v1/deposit/create")
async def api_deposit_create(api_key: str = Form(...), amount: float = Form(...), currency: str = Form("USDT")):
    """Create a deposit and return NowPayments invoice or static address."""
    user = _verify_api_key(api_key)
    if not user:
        raise HTTPException(401, "Invalid API key")
    if amount < 2:
        raise HTTPException(400, "Minimum deposit is $2")

    order_id = f"ord_{uuid.uuid4().hex[:12]}"
    conn = get_db()
    conn.execute("INSERT INTO orders (order_id, user_id, order_type, amount_usd, payment_method, payment_status) VALUES (?,?,?,?,?,?)",
                 (order_id, user["user_id"], "deposit", amount, currency, "pending"))
    conn.commit()

    pay_address = ""
    nowpayments_id = None
    invoice_url = ""

    # Try NowPayments
    try:
        np_key = (os.getenv("NOWPAYMENTS_API_KEY") or "").strip()
        if np_key:
            # Non-blocking: run sync requests.post in executor thread
            loop = asyncio.get_event_loop()
            resp = await loop.run_in_executor(None, lambda: requests.post(
                "https://api.nowpayments.io/v1/invoice", json={
                    "price_amount": amount, "price_currency": "usd",
                    "pay_currency": currency.lower(), "ipn_callback_url":
                    "https://jhfguf.pythonanywhere.com/api/v2/nowpayments-ipn",
                    "order_id": order_id, "order_description": f"JobHunt Pro Deposit ${amount}"
                }, headers={"x-api-key": np_key}, timeout=10
            ))
            if resp.status_code == 201:
                data = resp.json()
                nowpayments_id = data.get("id")
                pay_address = data.get("pay_address", "")
                invoice_url = data.get("invoice_url", "")
                conn.execute("UPDATE orders SET pay_address=?, nowpayments_id=?, nowpayments_invoice_url=?, pay_currency=?, pay_amount=? WHERE order_id=?",
                             (pay_address, nowpayments_id, invoice_url, currency, amount, order_id))
                conn.commit()
    except Exception:
        pass

    conn.close()

    if not pay_address:
        addresses = get_payment_addresses()
        pay_address = addresses.get(currency.upper(), addresses.get("USDT", ""))

    return {
        "order_id": order_id,
        "amount": amount,
        "currency": currency,
        "pay_address": pay_address,
        "nowpayments_id": nowpayments_id,
        "invoice_url": invoice_url,
        "checkout_url": f"/checkout/{order_id}"
    }

@app.get("/api/v1/deposit/status/{order_id}")
async def api_deposit_status(order_id: str, api_key: str = ""):
    """Check deposit payment status."""
    user = _verify_api_key(api_key)
    if not user:
        raise HTTPException(401, "Invalid API key")
    conn = get_db()
    order = conn.execute("SELECT * FROM orders WHERE order_id=? AND user_id=?", (order_id, user["user_id"])).fetchone()
    conn.close()
    if not order:
        raise HTTPException(404, "Order not found")
    return {"order_id": order["order_id"], "status": order["payment_status"], "amount": order["amount_usd"]}

@app.get("/api/v1/orders")
async def api_orders(api_key: str = "", limit: int = 10):
    """List recent orders."""
    user = _verify_api_key(api_key)
    if not user:
        raise HTTPException(401, "Invalid API key")
    conn = get_db()
    rows = conn.execute("SELECT order_id, amount_usd, payment_method, payment_status, created_at FROM orders WHERE user_id=? ORDER BY created_at DESC LIMIT ?",
                         (user["user_id"], limit)).fetchall()
    conn.close()
    return [dict(r) for r in rows]

@app.get("/api/v1/campaigns")
async def api_campaigns(api_key: str = "", limit: int = 10):
    """List recent campaigns."""
    user = _verify_api_key(api_key)
    if not user:
        raise HTTPException(401, "Invalid API key")
    conn = get_db()
    rows = conn.execute("SELECT campaign_id, status, sent_count, created_at FROM campaigns WHERE user_id=? ORDER BY created_at DESC LIMIT ?",
                         (user["user_id"], limit)).fetchall()
    conn.close()
    return [dict(r) for r in rows]

@app.post("/api/v1/campaigns")
async def api_create_campaigns_json(request: Request):
    """Create a new campaign via JSON API (FIXED 2026-06-05)."""
    conn = None
    try:
        data = await request.json()
    except Exception:
        return JSONResponse({"error": "Invalid JSON body"}, status_code=400)

    api_key = data.get("api_key", "")
    profile_cv = data.get("profile_cv", data.get("cv_text", ""))
    company_count = int(data.get("company_count", data.get("companies", 0)))
    target_titles = data.get("target_titles", "")
    target_locations = data.get("target_locations", "")
    bouquet = data.get("bouquet", "")

    if not api_key or not profile_cv:
        return JSONResponse({"error": "api_key and profile_cv required"}, status_code=400)
    if company_count < 1:
        return JSONResponse({"error": "company_count must be >= 1"}, status_code=400)

    try:
        conn = get_db()
        user_row = conn.execute("SELECT * FROM users WHERE api_key = ? AND is_active = 1", (api_key,)).fetchone()
        if not user_row:
            if conn: conn.close()
            return JSONResponse({"error": "Invalid API key"}, status_code=401)
        user = dict(user_row)

        # Find matching tier
        tier = None
        for t in PRICING_TIERS:
            if t.get("companies") == company_count:
                tier = t
                break
        if not tier:
            if conn: conn.close()
            return JSONResponse({"error": f"No pricing tier for {company_count} companies"}, status_code=400)

        total_price = tier["price_usd"]
        if bouquet:
            for bname in bouquet.split(","):
                bname = bname.strip()
                if not bname: continue
                for b in BOUQUET_PACKAGES:
                    if b.get("bouquet") == bname:
                        total_price += b.get("price_usd", 0)
                        break

        if user.get("wallet_balance", 0) < total_price:
            if conn: conn.close()
            return JSONResponse({"error": "Insufficient balance"}, status_code=402)

        profile_id = conn.execute(
            "INSERT INTO cv_profiles (user_id, profile_name, cv_text) VALUES (?, ?, ?)",
            (user["user_id"], f"API Profile {datetime.now().strftime('%Y%m%d%H%M')}", profile_cv)
        ).lastrowid

        campaign_id = f"camp_{uuid.uuid4().hex[:16]}"
        order_id = f"ord_{uuid.uuid4().hex[:16]}"

        conn.execute(
            "INSERT INTO campaigns (campaign_id, user_id, profile_id, tier_name, company_count, "
            "target_titles, target_locations, bouquet, status, created_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?, 'pending', ?)",
            (campaign_id, user["user_id"], profile_id, tier["name"], company_count,
             target_titles, target_locations, bouquet, datetime.now().isoformat())
        )
        conn.execute(
            "INSERT INTO orders (order_id, user_id, campaign_id, amount_usd, payment_method, payment_status, created_at) "
            "VALUES (?, ?, ?, ?, 'wallet', 'completed', ?)",
            (order_id, user["user_id"], campaign_id, total_price, datetime.now().isoformat())
        )
        with WALLET_LOCK:
            conn.execute(
                "UPDATE users SET wallet_balance = wallet_balance - ?, total_spent = total_spent + ? WHERE user_id = ?",
                (total_price, total_price, user["user_id"])
            )
        conn.commit()
        conn.close()

        return JSONResponse({
            "campaign_id": campaign_id,
            "order_id": order_id,
            "status": "pending",
            "tier": tier["name"],
            "companies": company_count,
            "price_usd": total_price
        }, status_code=201)
    except Exception as e:
        if conn:
            try: conn.close()
            except Exception: pass
        logger.exception("api_create_campaigns_json")
        return JSONResponse({"error": str(e)}, status_code=500)

@app.get("/api/v1/wallet/transactions")
async def api_wallet_transactions(api_key: str = "", limit: int = 10):
    """List wallet transactions."""
    user = _verify_api_key(api_key)
    if not user:
        raise HTTPException(401, "Invalid API key")
    conn = get_db()
    rows = conn.execute("SELECT transaction_type, amount, description, created_at FROM wallet_transactions WHERE user_id=? ORDER BY created_at DESC LIMIT ?",
                         (user["user_id"], limit)).fetchall()
    conn.close()
    return [{"type": r["transaction_type"], "amount": r["amount"], "description": r["description"], "created_at": r["created_at"]} for r in rows]

@app.get("/api/v1/stats")
async def api_stats_v1(api_key: str = ""):
    """Get aggregated stats for current user."""
    user = _verify_api_key(api_key)
    if not user:
        raise HTTPException(401, "Invalid API key")
    uid = user["user_id"]
    conn = get_db()
    total_campaigns = conn.execute("SELECT COUNT(*) FROM campaigns WHERE user_id=?", (uid,)).fetchone()[0]
    active_campaigns = conn.execute("SELECT COUNT(*) FROM campaigns WHERE user_id=? AND status='running'", (uid,)).fetchone()[0]
    total_sent = conn.execute("SELECT COALESCE(SUM(sent_count),0) FROM campaigns WHERE user_id=?", (uid,)).fetchone()[0]
    total_responses = conn.execute("SELECT COALESCE(SUM(response_count),0) FROM campaigns WHERE user_id=?", (uid,)).fetchone()[0]
    conn.close()
    return {
        "wallet_balance": user["wallet_balance"],
        "total_campaigns": total_campaigns,
        "active_campaigns": active_campaigns,
        "total_sent": total_sent,
        "total_responses": total_responses
    }

