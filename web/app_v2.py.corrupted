# ─── Helper: Create Notification ───
def create_notification(user_id: str, type: str, title: str, message: str = "", link: str = "", icon: str = "🔔"):
    """Create a notification for a user. Non-blocking, best-effort."""
    try:
        conn = get_db()
        conn.execute(
            "INSERT INTO notifications (user_id, type, title, message, link, icon) VALUES (?, ?, ?, ?, ?, ?)",
            (user_id, type, title, message, link, icon)
        )
        conn.commit()
        conn.close()
    except Exception:
        pass  # Non-critical, swallow errors


# ─── Feature C: Notification Center APIs ───
@app.get("/api/v1/notifications")
async def api_notifications(request: Request, limit: int = 20, unread_only: bool = False):
    """Get user notifications with unread count."""
    user = _get_session_user(request)
    if not user:
        return JSONResponse({"error": "Not authenticated"}, status_code=401)
    user_id = user.get("id")
    conn = None
    try:
        conn = get_db()
        conn.execute("""CREATE TABLE IF NOT EXISTS notifications (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            user_id TEXT NOT NULL, type TEXT NOT NULL DEFAULT 'info',
            title TEXT NOT NULL, message TEXT, link TEXT, icon TEXT DEFAULT '🔔',
            is_read INTEGER DEFAULT 0,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            FOREIGN KEY (user_id) REFERENCES users(user_id)
        )""")
        conn.execute("CREATE INDEX IF NOT EXISTS idx_notifications_user ON notifications(user_id, is_read, created_at DESC)")
        conn.commit()

        where = "WHERE user_id = ?"
        params = [user_id]
        if unread_only:
            where += " AND is_read = 0"

        total_unread = conn.execute(
            f"SELECT COUNT(*) FROM notifications {where}", params
        ).fetchone()[0]

        rows = conn.execute(
            f"SELECT * FROM notifications {where} ORDER BY created_at DESC LIMIT ?",
            params + [limit]
        ).fetchall()

        return JSONResponse({
            "notifications": [dict(r) for r in rows],
            "unread_count": total_unread,
            "total": len(rows)
        })
    finally:
        if conn:
            conn.close()


@app.post("/api/v1/notifications/read")
async def api_notifications_mark_read(request: Request):
    """Mark a single notification as read."""
    user = _get_session_user(request)
    if not user:
        return JSONResponse({"error": "Not authenticated"}, status_code=401)
    try:
        data = await request.json()
        notif_id = data.get("id")
        if not notif_id:
            return JSONResponse({"error": "Notification id required"}, status_code=400)
        conn = get_db()
        conn.execute(
            "UPDATE notifications SET is_read = 1 WHERE id = ? AND user_id = ?",
            (notif_id, user.get("id"))
        )
        conn.commit()
        conn.close()
        return JSONResponse({"success": True})
    except Exception as e:
        return JSONResponse({"error": str(e)}, status_code=500)


@app.post("/api/v1/notifications/read-all")
async def api_notifications_mark_all_read(request: Request):
    """Mark all notifications as read."""
    user = _get_session_user(request)
    if not user:
        return JSONResponse({"error": "Not authenticated"}, status_code=401)
    try:
        conn = get_db()
        conn.execute(
            "UPDATE notifications SET is_read = 1 WHERE user_id = ? AND is_read = 0",
            (user.get("id"),)
        )
        conn.commit()
        conn.close()
        return JSONResponse({"success": True})
    except Exception as e:
        return JSONResponse({"error": str(e)}, status_code=500)


# ─── Feature B: Smart Auto-Complete for Campaign Setup ───
@app.get("/api/v1/cv-auto-suggest")
async def api_cv_auto_suggest(request: Request, profile_id: int = None):
    """Extract job titles, skills, locations, company suggestions from user's CV profiles."""
    user = _get_session_user(request)
    if not user:
        return JSONResponse({"error": "Not authenticated"}, status_code=401)
    user_id = user.get("id")
    conn = None
    try:
        conn = get_db()
        if profile_id:
            profiles = [dict(r) for r in conn.execute(
                "SELECT * FROM cv_profiles WHERE user_id = ? AND id = ?", (user_id, profile_id)
            ).fetchall()]
        else:
            profiles = [dict(r) for r in conn.execute(
                "SELECT * FROM cv_profiles WHERE user_id = ?", (user_id,)
            ).fetchall()]

        if not profiles:
            return JSONResponse({"suggestions": {}, "message": "No CV profiles found. Upload your CV first."})

        # Aggregate data from all profiles
        all_skills = set()
        all_titles = set()
        all_locations = set()
        all_companies = set()

        for p in profiles:
            skills = p.get("skills", "")
            if skills:
                for s in skills.replace(",", ",").split(","):
                    s = s.strip()
                    if s and len(s) > 1:
                        all_skills.add(s)

            titles = p.get("target_titles", "")
            if titles:
                for t in titles.split(","):
                    t = t.strip()
                    if t and len(t) > 2:
                        all_titles.add(t)

            locations = p.get("target_locations", "")
            if locations:
                for l in locations.split(","):
                    l = l.strip()
                    if l and len(l) > 1:
                        all_locations.add(l)

        # Smart industry to company mapping
        industry_map = {
            "network": ["Cisco", "Juniper", "Fortinet", "Palo Alto", "Aruba", "Arista", "Huawei", "Nokia", "Ericsson"],
            "telecom": ["Touch Lebanon", "Alfa Telecom", "Ogero", "Zain", "STC", "Etisalat", "Du", "Ooredoo", "MTN"],
            "banking": ["Bank Audi", "BLOM Bank", "Byblos Bank", "Bank of Beirut", "Fransabank", "SGBL"],
            "cloud": ["AWS", "Google Cloud", "Microsoft Azure", "Oracle Cloud", "DigitalOcean"],
            "enterprise": ["Murex", "CME Offshore", "Azadea", "Malia Group", "Berytech", "Touch", "Alfa"],
            "security": ["Kaspersky", "Palo Alto", "CrowdStrike", "Fortinet", "Check Point", "CyberArk"],
            "isp": ["Ogero", "Sodetel", "IDM", "Terranet", "Cyberia", "Wise"],
            "oil_gas": ["TotalEnergies", "Shell", "Schlumberger", "Halliburton", "Petrofac"],
        }

        # Detect industries from skills
        detected_industries = set()
        cv_lower = (" ".join(all_skills) + " " + " ".join(all_titles)).lower()
        for industry, companies in industry_map.items():
            keywords = {
                "network": ["network", "cisco", "juniper", "router", "switch", "firewall", "ccna", "ccnp", "bgp", "ospf", "mpls", "sd-wan"],
                "telecom": ["telecom", "5g", "4g", "lte", "fiber", "isp", "broadband"],
                "banking": ["banking", "fintech", "finance", "payment"],
                "cloud": ["cloud", "aws", "azure", "gcp", "devops", "kubernetes", "docker"],
                "enterprise": ["enterprise", "corporate", "erp", "sap"],
                "security": ["security", "cyber", "firewall", "pentest", "siem", "soc"],
                "isp": ["isp", "internet service", "broadband", "fiber"],
                "oil_gas": ["oil", "gas", "petroleum", "energy"],
            }
            for kw in keywords.get(industry, []):
                if kw in cv_lower:
                    detected_industries.add(industry)
                    all_companies.update(companies)
                    break

        # Add default companies if none detected
        if not all_companies:
            all_companies.update([
                "Murex", "CME Offshore", "Bank Audi", "BLOM Bank", "Byblos Bank",
                "Touch Lebanon", "Alfa Telecom", "Azadea", "Malia Group", "Berytech",
                "Cisco", "Juniper", "Fortinet", "Palo Alto", "AWS", "Google"
            ])

        return JSONResponse({
            "suggestions": {
                "job_titles": sorted(all_titles),
                "skills": sorted(all_skills),
                "locations": sorted(all_locations),
                "companies": sorted(all_companies),
                "industries_detected": sorted(detected_industries)
            }
        })
    finally:
        if conn:
            conn.close()


# ─── Feature A: AI Job Match Score Widget ───
@app.post("/api/v1/job-match-score")
async def api_job_match_score(request: Request):
    """Score a user's CV against a specific job description - returns detailed match breakdown."""
    user = _get_session_user(request)
    if not user:
        return JSONResponse({"error": "Not authenticated"}, status_code=401)
    user_id = user.get("id")
    try:
        data = await request.json()
        job_title = data.get("job_title", "")
        job_desc = data.get("job_description", "")
        company = data.get("company", "")
        profile_id = data.get("profile_id")

        if not job_desc or not job_title:
            return JSONResponse({"error": "Job title and description required"}, status_code=400)

        # Get user's CV text
        conn = get_db()
        if profile_id:
            profile = conn.execute(
                "SELECT cv_text, skills FROM cv_profiles WHERE user_id = ? AND id = ?",
                (user_id, profile_id)
            ).fetchone()
        else:
            profile = conn.execute(
                "SELECT cv_text, skills FROM cv_profiles WHERE user_id = ? ORDER BY id DESC LIMIT 1",
                (user_id,)
            ).fetchone()
        conn.close()

        cv_text = ""
        skills_str = ""
        if profile:
            cv_text = profile["cv_text"] or ""
            skills_str = profile["skills"] or ""

        if not cv_text:
            return JSONResponse({
                "match_score": 0,
                "skill_match_pct": 0,
                "keyword_matches": [],
                "missing_keywords": [],
                "skills_gaps": ["Upload your CV first to get match scores"],
                "recommendation": "Upload your CV to see match scores",
                "is_fallback": True
            })

        # Quick local scoring (keyword matching)
        cv_lower = cv_text.lower()
        jd_lower = job_desc.lower()
        user_skills = [s.strip().lower() for s in skills_str.split(",") if s.strip()]

        # Extract keywords from job description
        import re as _re3
        tech_keywords = set()
        common_tech = [
            "python", "java", "javascript", "sql", "aws", "azure", "docker", "kubernetes",
            "linux", "git", "agile", "scrum", "react", "angular", "node", "typescript",
            "cisco", "juniper", "fortinet", "palo alto", "bgp", "ospf", "mpls", "vpn",
            "firewall", "ccna", "ccnp", "sd-wan", "vlan", "tcp/ip", "dns", "dhcp",
            "mikrotik", "ubiquiti", "network", "security", "cloud", "devops", "ci/cd",
            "terraform", "ansible", "jenkins", "grafana", "prometheus", "nginx", "apache",
            "mongodb", "postgresql", "mysql", "redis", "elasticsearch", "kafka",
            "power bi", "tableau", "excel", "salesforce", "sap", "oracle",
            "project management", "pmp", "prince2", "itil", "servicenow",
            "routing", "switching", "wan", "lan", "nat", "qos", "ipv6",
            "aruba", "meraki", "sophos", "checkpoint", "f5", "citrix"
        ]
        for kw in common_tech:
            if kw in jd_lower:
                tech_keywords.add(kw)

        # Also extract capitalized acronyms from JD
        for match in _re3.finditer(r'\b[A-Z]{2,6}\b', job_desc):
            word = match.group().lower()
            if word not in ["the", "and", "for", "our", "you", "are", "all"]:
                tech_keywords.add(word)

        # Match analysis
        keyword_matches = []
        missing_keywords = []
        for kw in tech_keywords:
            if kw in cv_lower:
                keyword_matches.append(kw.upper())
            else:
                missing_keywords.append(kw.upper())

        # Skill match percentage
        skill_match_count = 0
        for us in user_skills:
            if us and us in jd_lower:
                skill_match_count += 1
        skill_match_pct = round((skill_match_count / max(len(user_skills), 1)) * 100)

        # Overall match score (weighted)
        kw_score = round((len(keyword_matches) / max(len(tech_keywords), 1)) * 60)
        skill_score = min(skill_match_pct * 0.4, 40)
        match_score = min(kw_score + int(skill_score), 100)

        # Skills gaps
        skills_gaps = []
        if missing_keywords:
            top_missing = missing_keywords[:5]
            skills_gaps.append(f"Missing keywords: {', '.join(top_missing)}")
        if skill_match_pct < 50:
            skills_gaps.append(f"Only {skill_match_pct}% of your listed skills match this job")
        if not skills_gaps:
            skills_gaps.append("Great match! Your skills align well with this position.")

        # Recommendation
        if match_score >= 80:
            recommendation = "Strong match! Consider this a high-priority application."
        elif match_score >= 60:
            recommendation = "Good match. Tailor your resume to highlight matching keywords."
        elif match_score >= 40:
            recommendation = "Moderate match. Use Resume Tailor to optimize your CV for this role."
        else:
            recommendation = "Low match. Review job requirements and consider upskilling."

        return JSONResponse({
            "match_score": match_score,
            "skill_match_pct": skill_match_pct,
            "keyword_matches": keyword_matches[:10],
            "missing_keywords": missing_keywords[:8],
            "skills_gaps": skills_gaps,
            "recommendation": recommendation,
            "is_fallback": False
        })
    except Exception as e:
        logger.exception("job-match-score failed")
        return JSONResponse({"error": str(e)}, status_code=500)


@app.post("/api/v1/job-match-score-groq")
async def api_job_match_score_groq(request: Request):
    """Deep AI-powered match score using Groq - analyzes semantic fit."""
    user = _get_session_user(request)
    if not user:
        return JSONResponse({"error": "Not authenticated"}, status_code=401)
    user_id = user.get("id")
    try:
        data = await request.json()
        job_title = data.get("job_title", "")
        job_desc = data.get("job_description", "")
        company = data.get("company", "")
        profile_id = data.get("profile_id")

        if not job_desc or not job_title:
            return JSONResponse({"error": "Job title and description required"}, status_code=400)

        conn = get_db()
        if profile_id:
            profile = conn.execute(
                "SELECT cv_text, skills FROM cv_profiles WHERE user_id = ? AND id = ?",
                (user_id, profile_id)
            ).fetchone()
        else:
            profile = conn.execute(
                "SELECT cv_text, skills FROM cv_profiles WHERE user_id = ? ORDER BY id DESC LIMIT 1",
                (user_id,)
            ).fetchone()
        conn.close()

        cv_text = profile["cv_text"] if profile else ""
        if not cv_text:
            return JSONResponse({"error": "No CV found. Upload your CV first."}, status_code=400)

        import os as _os, random as _random
        groq_key = _os.getenv("GROQ_API_KEY", "")
        if not groq_key and GROQ_KEYS:
            groq_key = _random.choice([k for k in GROQ_KEYS if k])
        if not groq_key:
            return JSONResponse({"error": "AI service not configured"}, status_code=503)

        import httpx as _httpx
        async with _httpx.AsyncClient(timeout=30) as client:
            resp = await client.post(
                "https://api.groq.com/openai/v1/chat/completions",
                headers={"Authorization": f"Bearer {groq_key}", "Content-Type": "application/json"},
                json={
                    "model": "llama-3.1-8b-instant",
                    "messages": [{
                        "role": "system",
                        "content": "You are an ATS (Applicant Tracking System) expert. Score a resume against a job description. Return ONLY valid JSON."
                    }, {
                        "role": "user",
                        "content": f"""Score this CV against the job. Return JSON:
{{"match_score": 85, "skills_match": ["BGP", "OSPF"], "missing_skills": ["AWS", "Python"],
"experience_fit": "Strong", "education_fit": "Match",
"summary": "2-sentence analysis", "recommendation": "Apply now / Tailor first / Low match"}}

=== JOB: {job_title} at {company} ===
{job_desc[:2500]}

=== CV ===
{cv_text[:2500]}"""
                    }],
                    "temperature": 0.3,
                    "max_tokens": 500,
                    "response_format": {"type": "json_object"}
                }
            )
            if resp.status_code != 200:
                return JSONResponse({"error": f"AI error: HTTP {resp.status_code}"}, status_code=502)
            result = resp.json()
            ai_output = json.loads(result["choices"][0]["message"]["content"])
            ai_output["ai_powered"] = True
            return JSONResponse(ai_output)

    except Exception as e:
        logger.exception("job-match-score-groq failed")
        return JSONResponse({"error": str(e)}, status_code=500)


# ─── Feature A: Update match score for campaign emails ───
@app.post("/api/v1/campaign-emails/{email_id}/match-score")
async def api_update_email_match_score(request: Request, email_id: int):
    """Calculate and store match score for a specific campaign email."""
    user = _get_session_user(request)
    if not user:
        return JSONResponse({"error": "Not authenticated"}, status_code=401)
    user_id = user.get("id")
    try:
        conn = get_db()
        email_row = conn.execute(
            "SELECT ce.*, c.user_id FROM campaign_emails ce JOIN campaigns c ON ce.campaign_id = c.campaign_id WHERE ce.id = ?",
            (email_id,)
        ).fetchone()
        if not email_row or email_row["user_id"] != user_id:
            conn.close()
            return JSONResponse({"error": "Email not found"}, status_code=404)

        email_data = dict(email_row)

        # Get CV
        profile = conn.execute(
            "SELECT cv_text, skills FROM cv_profiles WHERE user_id = ? ORDER BY id DESC LIMIT 1",
            (user_id,)
        ).fetchone()
        cv_text = profile["cv_text"] if profile else ""

        if not cv_text:
            conn.close()
            return JSONResponse({"error": "Upload CV first"}, status_code=400)

        # Build job description from email data
        job_desc = f"{email_data.get('job_title', '')} at {email_data.get('company_name', '')}"
        if email_data.get("job_location"):
            job_desc += f" in {email_data['job_location']}"

        cv_lower = cv_text.lower()
        jd_lower = job_desc.lower()

        # Quick keyword match
        tech_kw = ["bgp", "ospf", "mpls", "vpn", "firewall", "cisco", "juniper", "fortinet",
                    "ccna", "ccnp", "sd-wan", "vlan", "tcp/ip", "dns", "dhcp", "nat", "qos",
                    "mikrotik", "ubiquiti", "network", "security", "cloud", "linux", "routing", "switching"]
        matches = sum(1 for kw in tech_kw if kw in cv_lower and kw in jd_lower)
        total = sum(1 for kw in tech_kw if kw in jd_lower)
        score = min(round((matches / max(total, 1)) * 100), 100) if total > 0 else 50

        conn.execute("UPDATE campaign_emails SET match_score = ? WHERE id = ?", (score, email_id))
        conn.commit()
        conn.close()

        return JSONResponse({"success": True, "match_score": score})
    except Exception as e:
        return JSONResponse({"error": str(e)}, status_code=500)
