@app.get("/sent-emails", response_class=HTMLResponse)
async def sent_emails_page(request: Request):
    """Show all sent emails with company names, from-email, status."""
    user_id = get_verified_user_id(request)
    if not user_id:
        return RedirectResponse("/login")

    conn = get_db()
    rows = conn.execute('''
        SELECT ce.id, ce.company_name, ce.job_title, ce.email_address,
               ce.status, ce.tracking_id, ce.sent_at, ce.opened_at, ce.responded_at,
               ce.response_type, ce.followup_count, ce.pipeline_stage
        FROM campaign_emails ce
        JOIN campaigns c ON ce.campaign_id = c.campaign_id
        WHERE c.user_id = ?
        ORDER BY ce.sent_at DESC
        LIMIT 500
    ''', (user_id,)).fetchall()
    user_row = conn.execute("SELECT * FROM users WHERE user_id = ?", (user_id,)).fetchone()
    user = dict(user_row) if user_row else {}
    conn.close()

    total = len(rows)
    opened_count = sum(1 for r in rows if r["opened_at"])
    responded_count = sum(1 for r in rows if r["responded_at"])
    delivered_count = sum(1 for r in rows if r["status"] in ("sent", "delivered"))
    bounced_count = sum(1 for r in rows if r["status"] in ("failed", "bounced"))
    # Convert sqlite3.Row objects to dicts for Jinja2 iteration
    email_rows = [dict(r) for r in rows]
    return templates.TemplateResponse("sent_emails.html", {
        "request": request,
        "active_page": "sent-emails",
        "user": user,
        "rows": email_rows,
        "total": total,
        "opened_count": opened_count,
        "responded_count": responded_count,
        "delivered_count": delivered_count,
        "bounced_count": bounced_count,
    })



