@app.post("/api/v1/resume-tailor")
async def api_resume_tailor(request: Request):
    """Tailor a resume to match a specific job description using Groq AI."""
    try:
        data = await request.json()
        resume = data.get("resume", "")
        job_desc = data.get("job_description", "")
        job_title = data.get("job_title", "")
        premium = data.get("premium", False)

        if not resume or not job_desc:
            return JSONResponse({"error": "Both resume and job description are required"}, status_code=400)

        if len(resume) < 50 or len(job_desc) < 50:
            return JSONResponse({"error": "Resume and job description must each be at least 50 characters"}, status_code=400)

        # Build the AI prompt
        system_prompt = """You are an expert resume writer and ATS (Applicant Tracking System) optimization specialist.
Your job is to rewrite the candidate's resume to maximize match with a specific job description.

RULES:
1. NEVER fabricate experience, skills, or qualifications the candidate doesn't have.
2. Reorder, rephrase, and emphasize existing skills/experience to match the job description.
3. Add keywords from the job description that the candidate implicitly has (based on their experience).
4. Quantify achievements where possible (add numbers if the candidate's text implies them).
5. Keep the same professional tone; don't over-hype.
6. Structure: Professional Summary → Skills → Experience → Certifications → Education.
7. Return ONLY valid JSON - no markdown, no explanations outside the JSON."""

        user_prompt = f"""JOB TITLE: {job_title or 'See job description'}

=== JOB DESCRIPTION ===
{job_desc[:3000]}

=== CANDIDATE'S RESUME ===
{resume[:4000]}

=== TASK ===
Rewrite the resume to maximize ATS match for this job. Return a JSON object with these fields:
{{
  "tailored_resume": "Full rewritten resume text",
  "keywords_added": ["keyword1", "keyword2"],
  "keywords_removed": ["old1"],
  "match_score": 85,
  "bullet_points_optimized": 5,
  "summary_of_changes": "Brief explanation of what was changed and why"
}}"""

        import os, random
        import httpx
        groq_key = os.getenv("GROQ_API_KEY", "")
        if not groq_key:
            # Use rotation keys
            groq_key = random.choice(GROQ_KEYS) if GROQ_KEYS else ""

        if not groq_key:
            return JSONResponse({"error": "AI service not configured. Contact support."}, status_code=500)

        model = "llama-3.1-8b-instant" if not premium else "llama-3.3-70b-versatile"

        async with httpx.AsyncClient(timeout=45) as client:
            resp = await client.post(
                "https://api.groq.com/openai/v1/chat/completions",
                headers={"Authorization": f"Bearer {groq_key}", "Content-Type": "application/json"},
                json={
                    "model": model,
                    "messages": [
                        {"role": "system", "content": system_prompt},
                        {"role": "user", "content": user_prompt}
                    ],
                    "temperature": 0.5,
                    "max_tokens": 3000,
                    "response_format": {"type": "json_object"}
                }
            )

            if resp.status_code != 200:
                logger.warning(f"Groq resume tailor: HTTP {resp.status_code}: {resp.text[:200]}")
                return JSONResponse({"error": f"AI service error: HTTP {resp.status_code}"}, status_code=502)

            result = resp.json()
            content_text = result["choices"][0]["message"]["content"]

            # Parse the AI response
            import json as json_lib
            tailored = json_lib.loads(content_text)
            tailored["model"] = model
            tailored["job_title"] = job_title

            return JSONResponse(tailored)

    except json.JSONDecodeError:
        logger.exception("resume-tailor: JSON parse error")
        return JSONResponse({"error": "AI response could not be parsed. Try again with more detailed input."}, status_code=500)
    except Exception as e:
        logger.exception("resume-tailor failed")
        return JSONResponse({"error": str(e)}, status_code=500)


