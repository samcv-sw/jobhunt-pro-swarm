@app.get("/sitemap.xml")
async def sitemap_xml():
    """Sitemap.xml - list all public pages."""
    base_url = "https://jhfguf.pythonanywhere.com"
    pages = [
        {"loc": "/", "priority": "1.0", "changefreq": "daily"},
        {"loc": "/pricing", "priority": "0.9", "changefreq": "weekly"},
        {"loc": "/faq", "priority": "0.7", "changefreq": "monthly"},
        {"loc": "/terms", "priority": "0.3", "changefreq": "yearly"},
        {"loc": "/privacy", "priority": "0.3", "changefreq": "yearly"},
        {"loc": "/blog", "priority": "0.8", "changefreq": "weekly"},
        {"loc": "/api-docs", "priority": "0.8", "changefreq": "monthly"},
        {"loc": "/login", "priority": "0.6", "changefreq": "monthly"},
        {"loc": "/register", "priority": "0.6", "changefreq": "monthly"},
        {"loc": "/contact", "priority": "0.5", "changefreq": "monthly"},
    ]
    urls = "\n".join(
        f'  <url><loc>{base_url}{p["loc"]}</loc><priority>{p["priority"]}</priority><changefreq>{p["changefreq"]}</changefreq></url>'
        for p in pages
    )
    xml = f"""<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{urls}
</urlset>"""
    return Response(content=xml, media_type="application/xml")


