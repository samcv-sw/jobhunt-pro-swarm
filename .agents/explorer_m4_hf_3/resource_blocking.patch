diff --git a/core/ghost_applicant.py b/core/ghost_applicant.py
index e123456..f654321 1006e
--- a/core/ghost_applicant.py
+++ b/core/ghost_applicant.py
@@ -45,8 +45,26 @@ class GhostApplicant:
 
                 page = await context.new_page()
 
+                # Setup image and tracker blocking using Playwright routing to save bandwidth (keep CSS/fonts for form layout)
+                import re
+                BLOCKED_RESOURCE_TYPES = {"image", "media"}
+                BLOCKED_DOMAINS_PATTERNS = [
+                    re.compile(p) for p in [
+                        r"analytics",
+                        r"google-analytics\.com",
+                        r"doubleclick",
+                        r"tracker",
+                        r"facebook\.com",
+                        r"fbcdn"
+                    ]
+                ]
+
+                async def route_intercept(route, request):
+                    if request.resource_type in BLOCKED_RESOURCE_TYPES:
+                        await route.abort()
+                    elif any(pat.search(request.url) for pat in BLOCKED_DOMAINS_PATTERNS):
+                        await route.abort()
+                    else:
+                        await route.continue_()
+
+                await page.route("**/*", route_intercept)
+                logger.info("[GhostApplicant] Resource blocking configured (images, trackers).")
+
                 # Setup timeout and navigate
                 page.set_default_timeout(30000)
                 await page.goto(url, wait_until="networkidle")
