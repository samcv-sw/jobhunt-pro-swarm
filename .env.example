# ============================================
# JobHunt Pro - Environment Variables
# Copy to .env and fill in your values
# ============================================
#
# FOR CLOUD DEPLOYMENT (Render.com):
#   Do NOT edit this file for cloud secrets.
#   Set ALL env vars in Render Dashboard -> Environment tab instead.
#   See CLOUD_DEPLOYMENT.md for step-by-step instructions.
#
#   Required cloud secrets (set in Dashboard):
#     GROQ_API_KEY, JSEARCH_API_KEY, GMAIL_SMTP_USER_1, GMAIL_APP_PASSWORD_1,
#     BREVO_API_KEY, BREVO_ACCOUNT_EMAIL, TELEGRAM_BOT_TOKEN, TELEGRAM_CHAT_ID,
#     SECRET_KEY
#
#   Cloud defaults (set automatically if not provided):
#     CLOUD_MODE=true, MAX_WORKERS=50, CYCLE_INTERVAL=60, DRY_RUN=true

# ── Candidate Info ──────────────────────────
CANDIDATE_EMAIL=your_email@gmail.com
CANDIDATE_PHONE=+961 71 019 053
CANDIDATE_ADDRESS=Beirut, Lebanon
CV_PATH=assets/Sam_Salameh_CV.pdf

# ── AI APIs (Multi-Provider Fallback) ──────
# Groq (Free: 14,400 req/day, 30 rpm)
# Add multiple keys for rotation: GROQ_API_KEY_2, GROQ_API_KEY_3, etc.
GROQ_API_KEY=your_groq_key

# Google Gemini (Free: 60 req/min)
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key

# Hugging Face (Free: ~10,000 req/day)
HUGGINGFACE_API_KEY=

# Together AI (Free tier)
TOGETHER_API_KEY=

# Perplexity (Free: 5 req/hour)
PERPLEXITY_API_KEY=


# ── Telegram ───────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── Email Providers (10+ providers = 1,300+ emails/day FREE) ────

# 1. Brevo HTTP API (Free: 300 emails/day, works on Render)
# Sign up: https://www.brevo.com
# USE this method — it bypasses SMTP port restrictions on cloud:
BREVO_API_KEY=your_brevo_api_key
BREVO_ACCOUNT_EMAIL=your_verified_brevo_sender@example.com

# 1b. Brevo SMTP (alternative, port 2525 works on Render)
BREVO_SMTP_LOGIN=your_brevo_email
BREVO_SMTP_PASSWORD=your_brevo_smtp_password

# ── ⚡ HYPER MODE (Turbo) ───────────────────────────────────
# Hyper Mode = zero AI, pure template + parallel SMTP
# Target: 2000+ applications/hour with 10+ providers
HYPER_MODE_ENABLED=true
HYPER_TEST_MODE=false
HYPER_PARALLEL_WORKERS=20
HYPER_BATCH_SIZE=100
HYPER_SMTP_POOL_SIZE=50

# 2. Gmail SMTP (Free: 100/day per account, up to 10 = 1,000/day)
# Enable app passwords: https://myaccount.google.com/apppasswords
GMAIL_SMTP_USER_1=your_gmail_1@gmail.com
GMAIL_APP_PASSWORD_1=your_app_password_1
GMAIL_SMTP_USER_2=your_gmail_2@gmail.com
GMAIL_APP_PASSWORD_2=your_app_password_2
GMAIL_SMTP_USER_3=
GMAIL_APP_PASSWORD_3=
GMAIL_SMTP_USER_4=
GMAIL_APP_PASSWORD_4=
GMAIL_SMTP_USER_5=
GMAIL_APP_PASSWORD_5=
GMAIL_SMTP_USER_6=
GMAIL_APP_PASSWORD_6=
GMAIL_SMTP_USER_7=
GMAIL_APP_PASSWORD_7=
GMAIL_SMTP_USER_8=
GMAIL_APP_PASSWORD_8=
GMAIL_SMTP_USER_9=
GMAIL_APP_PASSWORD_9=
GMAIL_SMTP_USER_10=
GMAIL_APP_PASSWORD_10=

# 3. Outlook/Hotmail (Free: 300/day, up to 3 = 900/day)
OUTLOOK_USER_1=your_outlook_1@outlook.com
OUTLOOK_PASSWORD_1=your_outlook_password_1
OUTLOOK_USER_2=
OUTLOOK_PASSWORD_2=
OUTLOOK_USER_3=
OUTLOOK_PASSWORD_3=

# 4. Zoho Mail (Free: 500/day per account, up to 3 = 1,500/day)
# Sign up: https://www.zoho.com/mail
ZOHO_USER_1=your_zoho_1@zoho.com
ZOHO_PASSWORD_1=your_zoho_password_1
ZOHO_USER_2=
ZOHO_PASSWORD_2=
ZOHO_USER_3=
ZOHO_PASSWORD_3=

# 5. Yahoo Mail (Free: 500/day)
YAHOO_SMTP_USER=your_yahoo@yahoo.com
YAHOO_APP_PASSWORD=your_yahoo_password

# 6. Resend API (Free: 3,000/month = 100/day, BEST deliverability!)
# Requires verified custom domain
RESEND_API_KEY=your_resend_key
RESEND_API_KEY_2=
RESEND_API_KEY_3=
RESEND_FROM_EMAIL=your_verified_domain@yourdomain.com

# 7. Mailjet API (Free: 6,000/month = 200/day, HTTP API works on Render)
MAILJET_API_KEY=your_mailjet_key
MAILJET_API_SECRET=your_mailjet_secret

# 8. SendPulse API (Free: 12,000/month = 400/day)
# Sign up: https://sendpulse.com
SENDPULSE_API_KEY=
SENDPULSE_CLIENT_ID=
SENDPULSE_CLIENT_SECRET=

# ── Database ────────────────────────────────
DATABASE_URL=postgresql+asyncpg://jobhunt:password@localhost:5432/jobhunt_pro
DATABASE_URL_SYNC=postgresql://jobhunt:password@localhost:5432/jobhunt_pro
DB_PASSWORD=your_db_password

# ── Redis ───────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── App Settings ────────────────────────────
MAX_WORKERS=200
DAILY_SEND_LIMIT=2000
SECRET_KEY=change-this-to-random-string

# ── Rita Cordahi Profile (Second Profile Support) ──────
# Enable by setting RITA_PROFILE_ENABLED=true and using core.rita_profile
RITA_PROFILE_ENABLED=false
RITA_NAME=Rita Cordahi
RITA_TITLE=HR & Customer Operations Specialist
RITA_EMAIL=ritacordahi2@gmail.com
RITA_PHONE=+961 76 005 412
RITA_ADDRESS=Beirut, Lebanon
RITA_LINKEDIN=https://www.linkedin.com/in/rita-cordahi/
RITA_YEARS_EXPERIENCE=6
RITA_CV_PATH=assets/Rita_Cordahi_CV.pdf
RITA_DAILY_SEND_LIMIT=75
RITA_MIN_SALARY=1000
RITA_TARGET_SALARY=1500
RITA_GROQ_API_KEY=
RITA_TELEGRAM_BOT_TOKEN=
RITA_TELEGRAM_CHAT_ID=
RITA_BREVO_API_KEY=
RITA_BREVO_ACCOUNT_EMAIL=
RITA_BREVO_SMTP_LOGIN=
RITA_BREVO_SMTP_PASSWORD=
RITA_GMAIL_SMTP_USER=
RITA_GMAIL_APP_PASSWORD=

# ── Crypto Wallet Addresses (for deposit feature) ─
CRYPTO_BTC_ADDRESS=your_btc_address
CRYPTO_ETH_ADDRESS=your_eth_address
CRYPTO_USDT_ADDRESS=your_usdt_address
CRYPTO_LTC_ADDRESS=your_ltc_address

# ── Cloud Deployment ────────────────────────
# Railway: Just set these in the dashboard
# Render: Use environment group
# Fly.io: Set with fly secrets set
