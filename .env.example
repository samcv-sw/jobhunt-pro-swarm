# ══════════════════════════════════════════════════════════════════════════════
# JobHunt Pro — Environment Configuration Template
# Copy this to .env and fill in the values for production deployments.
# ══════════════════════════════════════════════════════════════════════════════

# ── Security & Authentication ────────────────────────────────────────────────
# Secret key used for signing session cookies (itsdangerous). Generate a long random string.
SECRET_KEY=super-secret-session-signing-key-change-me

# JWT secret key for OAuth / stateless APIs. Must be at least 32 characters long.
JWT_SECRET_KEY=jobhunt-pro-secret-key-32bytes-must-be-changed-in-production

# Webhook secret keys to verify incoming payment receipts
STRIPE_WEBHOOK_SECRET=
SELLIX_WEBHOOK_SECRET=

# ── Admin Controls ──────────────────────────────────────────────────────────
# Default admin email overrides (space/comma separated)
ADMIN_EMAIL=samsalameh.cv@gmail.com,samatou683@gmail.com

# Password hash to override admin credentials during rescue procedures
ADMIN_PW_HASH=

# PythonAnywhere API Token for system automation & resets
PA_API_TOKEN=

# ── LLM (Groq) Integration ──────────────────────────────────────────────────
# Primary Groq API Key for AI cover letter generation & resume tailoring
GROQ_API_KEY=gsk_your_groq_api_key_goes_here

# ── Database Strategy (Choose One) ──────────────────────────────────────────
# Strategy A: Local SQLite (Set FORCE_SQLITE=1)
FORCE_SQLITE=1

# Strategy B: Neon/Supabase PostgreSQL
DATABASE_URL=postgresql://user:pass@host:port/dbname?sslmode=require
SUPABASE_MODE=0

# Strategy C: Turso Cloud DB (libsql)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── Email Engine (SMTP & OAuth Cascade) ─────────────────────────────────────
# Primary sender Gmail account and App Password (security setting under Google Account)
GMAIL_SMTP_USER_1=
GMAIL_APP_PASSWORD_1=

# ── Cloudflare Defense ──────────────────────────────────────────────────────
# Turnstile CAPTCHA keys to prevent bot registrations
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=

# ── Developer Flags ─────────────────────────────────────────────────────────
# Enable simulate checkout routes for testing/staging environments
ALLOW_PAY_SIMULATE=false
