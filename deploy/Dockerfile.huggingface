# =============================================================================
# JobHunt Pro — Hugging Face Spaces Dockerfile (SCRAPERS & WORKERS)
# -----------------------------------------------------------------------------
# Platform : Hugging Face Spaces — Docker SDK (FREE: 2 vCPU, 16GB RAM, 24/7)
# Purpose  : Long-running Playwright scrapers + Celery workers
#
# To deploy:
#   1. Create a NEW Space on huggingface.co → SDK: Docker → public or private
#   2. Push this repo (or just this deploy/ folder) to the Space's git remote
#   3. HF will build this Dockerfile automatically
#
# Secrets (set in Space Settings → Secrets):
#   TURSO_DATABASE_URL
#   TURSO_AUTH_TOKEN
#   OPENAI_API_KEY
#   TELEGRAM_BOT_TOKEN
#   REDIS_URL            (optional, e.g. upstash free)
# =============================================================================

FROM python:3.12-slim

# ── System dependencies (Playwright needs Chromium libs) ─────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    wget \
    gnupg \
    libglib2.0-0 \
    libnss3 \
    libnspr4 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libdbus-1-3 \
    libexpat1 \
    libxcb1 \
    libxkbcommon0 \
    libx11-6 \
    libxcomposite1 \
    libxdamage1 \
    libxext6 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libpango-1.0-0 \
    libcairo2 \
    libasound2 \
    libatspi2.0-0 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# ── Python dependencies ───────────────────────────────────────────────────────
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Install Playwright browsers (Chromium only to save space)
RUN python -m playwright install chromium --with-deps 2>/dev/null || \
    python -m camoufox fetch 2>/dev/null || true

# ── Application source ────────────────────────────────────────────────────────
COPY scrapers/  ./scrapers/
COPY bot/       ./bot/
COPY backend/   ./backend/
COPY core/      ./core/
COPY config.py  ./config.py

RUN mkdir -p ./data && chmod 777 ./data

# ── Environment ───────────────────────────────────────────────────────────────
ENV PYTHONPATH=/app \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    # Hugging Face requires the app to listen on port 7860
    PORT=7860

EXPOSE 7860

# ── Startup: run both the Telegram bot AND the scraper worker ─────────────────
# Uses a simple shell script to launch background workers concurrently
COPY deploy/hf_entrypoint.sh /hf_entrypoint.sh
RUN chmod +x /hf_entrypoint.sh

CMD ["/hf_entrypoint.sh"]
