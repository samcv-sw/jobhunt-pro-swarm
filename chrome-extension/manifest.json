{
  "manifest_version": 3,
  "name": "JobHunt Pro — Auto-Apply to Jobs",
  "version": "1.0.0",
  "description": "AI-powered job application assistant. Auto-fills forms, generates cover letters, and applies to jobs in one click.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/jobs/*",
        "*://*.indeed.com/*",
        "*://*.glassdoor.com/*",
        "*://*.bayt.com/*",
        "*://*.ziprecruiter.com/*",
        "*://*.monster.com/*",
        "*://*.wuzzuf.net/*",
        "*://*.naukrigulf.com/*",
        "*://*.gulftalent.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "*://*.linkedin.com/*",
    "*://*.indeed.com/*",
    "*://*.glassdoor.com/*",
    "*://*.bayt.com/*",
    "*://*.ziprecruiter.com/*",
    "*://*.jhfguf.pythonanywhere.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "styles.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
