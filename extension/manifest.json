{
  "manifest_version": 3,
  "name": "JobHunt Pro Swarm Agent",
  "version": "2.0.0",
  "description": "The God-Mode Decentralized AI Job Application Engine.",
  "action": {
    "default_popup": "index.html",
    "default_title": "JobHunt Pro Dashboard"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/*", "*://*.indeed.com/*"],
      "js": ["src/content.ts"],
      "run_at": "document_end"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "*://*.linkedin.com/*",
    "*://*.indeed.com/*",
    "https://api.puter.com/*"
  ]
}
